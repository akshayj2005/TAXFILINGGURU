<header class="relative w-full bg-white/80 backdrop-blur-md shadow-sm top-0 z-50 border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-2 lg:py-4">
    <div class="flex justify-between items-center min-h-[80px] relative">

      <div class="flex items-center space-x-3">
        <a href="/" class="flex items-center">
          <img src="/assets/images/TFG_LOGO.png" alt="Tax Filing Guru Logo" class="h-10 md:h-16 w-auto"
            onerror="this.style.display='none';">
        </a>
        <div class="flex flex-col items-center leading-none text-center">
          <a href="/" class="inline-block">
            <div class="inline-flex flex-col items-center">
              <h1 id="company-name" class="font-heading text-[1.1rem] md:text-3xl font-bold text-gray-900 leading-none">
                Tax Filing <span class="text-blue-600">Guru</span>
              </h1>
              <span class="h-[2px] bg-blue-600 w-full mt-1"></span>
              <span class="text-[9px] md:text-xs text-black font-medium leading-none mt-1 text-center">
                Smart Taxes Need a Guru.
              </span>
            </div>
          </a>
        </div>
      </div>

      <nav class="hidden md:flex items-center space-x-8 leading-none ml-auto">

        <a href="/resident" class="h-10 flex items-center text-gray-700 hover:text-blue-600 font-bold transition gap-2">
          <i class="fa-solid fa-house-user text-blue-500"></i> Residents
        </a>
        <a href="/nri" class="h-10 flex items-center text-gray-700 hover:text-blue-600 font-bold transition gap-2">
          <i class="fa-solid fa-plane-departure text-blue-500"></i> NRI
        </a>

        <div class="relative group h-10 flex items-center">
          <a href="/tools"
            class="flex items-center text-gray-700 group-hover:text-blue-600 font-bold transition cursor-pointer gap-2">
            <i class="fa-solid fa-screwdriver-wrench text-blue-500"></i> Tools
            <svg class="w-4 h-4 ml-1 transform group-hover:rotate-180 transition-transform duration-200" fill="none"
              stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </a>
          <div
            class="absolute top-full left-0 mt-0 w-56 bg-white shadow-xl rounded-lg border border-gray-100 invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 z-50">
            <div class="absolute -top-2 left-6 w-4 h-4 bg-white transform rotate-45 border-l border-t border-gray-100">
            </div>
            <div class="py-2 relative bg-white rounded-lg overflow-hidden">
              <div class="px-4 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">
                Tools & Calculators</div>
              <a href="/refund-maximizer"
                class="block px-4 py-3 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition">Refund
                Maximizer</a>
              <a href="/regime-comparison"
                class="block px-4 py-3 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition">Regime
                Comparison</a>
              <a href="/nri-status"
                class="block px-4 py-3 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition">NRI Status
                Tracker</a>
              <a href="/trader-turnover"
                class="block px-4 py-3 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition">Trader
                Turnover</a>
              <a href="/refund-status"
                class="block px-4 py-3 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition">Refund
                Status</a>
              <a href="/tools"
                class="block px-4 py-3 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition border-t border-gray-100 font-bold">All
                Tools</a>
            </div>
          </div>
        </div>

        <a href="/contact" class="h-10 flex items-center text-gray-700 hover:text-blue-600 font-bold transition mr-4 gap-2">
          <i class="fa-solid fa-handshake-angle text-blue-500"></i> AID
        </a>
        <a href="/blogs" class="h-10 flex items-center text-gray-700 hover:text-blue-600 font-bold transition mr-4 gap-2">
          <i class="fa-solid fa-newspaper text-blue-500"></i> Blogs
        </a>
        <% if (locals.user) { %>
          <div class="flex items-center space-x-3">
            <a href="/dashboard/profile" class="h-10 w-10 flex items-center justify-center rounded-full overflow-hidden border-2 border-blue-500/20 hover:border-blue-500 transition-all shadow-sm" title="My Profile">
              <% if (user.profileImage) { %>
                <img src="<%= user.profileImage %>" alt="Profile" class="w-full h-full object-cover">
              <% } else { %>
                <i class="fa-solid fa-circle-user text-xl text-gray-700"></i>
              <% } %>
            </a>
            <a href="/dashboard" class="h-10 flex items-center bg-blue-50 text-blue-700 px-4 rounded-lg font-bold hover:bg-blue-100 transition whitespace-nowrap">
              <i class="fa-solid fa-gauge-high mr-2"></i> Dashboard
            </a>
            <a href="/logout" class="h-10 flex items-center px-4 rounded-lg bg-red-600 text-white font-bold hover:bg-red-700 transition shadow-lg shadow-red-100 border border-red-500" title="Logout">
              <i class="fa-solid fa-right-from-bracket mr-2"></i> Logout
            </a>
          </div>
        <% } else { %>
          <a href="/login" class="h-11 flex items-center bg-blue-600 text-white px-6 rounded-xl font-black hover:bg-blue-700 transition shadow-lg shadow-blue-100 gap-2 whitespace-nowrap">
            <i class="fa-solid fa-right-to-bracket"></i> Client Login
          </a>
        <% } %>
      </nav>

      <!-- HAMBURGER (MOBILE ONLY) -->
      <button id="hamburgerBtn"
        class="md:hidden flex items-center justify-center p-2 rounded-lg text-gray-900 hover:bg-gray-100 focus:outline-none z-50"
        aria-label="Open menu">

        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    <!-- MOBILE MENU -->
    <div id="mobileMenu" class="md:hidden hidden bg-white border-t border-gray-100 shadow-lg">

      <a href="/resident" class="block px-6 py-4 text-gray-700 hover:bg-blue-50">Residents</a>
      <a href="/nri" class="block px-6 py-4 text-gray-700 hover:bg-blue-50">NRI</a>

      <div>
        <button onclick="toggleMobileSubmenu('toolsSubmenu')"
          class="w-full flex justify-between items-center px-6 py-4 text-gray-700 hover:bg-blue-50 focus:outline-none">
          Tools
          <svg class="w-4 h-4 ml-1 transition-transform duration-200" fill="none" stroke="currentColor"
            viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        <div id="toolsSubmenu" class="hidden bg-gray-50 border-t border-gray-100">
          <a href="/refund-maximizer"
            class="block pl-10 pr-6 py-3 text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50">Refund
            Maximizer</a>
          <a href="/regime-comparison"
            class="block pl-10 pr-6 py-3 text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50">Regime
            Comparison</a>
          <a href="/nri-status"
            class="block pl-10 pr-6 py-3 text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50">NRI Status
            Tracker</a>
          <a href="/trader-turnover"
            class="block pl-10 pr-6 py-3 text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50">Trader Turnover</a>
          <a href="/refund-status"
            class="block pl-10 pr-6 py-3 text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50">Refund Status</a>
          <a href="/tools" class="block pl-10 pr-6 py-3 text-sm text-blue-600 font-bold hover:bg-blue-50">All
            Tools</a>
        </div>
      </div>
      
      <a href="/contact" class="block px-6 py-4 text-gray-700 hover:bg-blue-50 flex items-center gap-2">
        <i class="fa-solid fa-handshake-angle text-blue-500 w-5"></i> AID
      </a>
      <a href="/blogs" class="block px-6 py-4 text-gray-700 hover:bg-blue-50 flex items-center gap-2 border-b border-gray-100">
        <i class="fa-solid fa-newspaper text-blue-500 w-5"></i> Blogs
      </a>

      <% if (locals.user) { %>
        <a href="/dashboard/profile" class="block px-6 py-4 text-gray-700 hover:bg-blue-50 flex items-center gap-2">
          <% if (user.profileImage) { %>
            <img src="<%= user.profileImage %>" alt="Profile" class="h-6 w-6 rounded-full object-cover border border-blue-500/20">
          <% } else { %>
            <i class="fa-solid fa-circle-user text-blue-500"></i>
          <% } %>
          My Profile
        </a>
        <a href="/dashboard" class="block px-6 py-4 text-blue-600 font-bold bg-blue-50 flex items-center gap-2">
          <i class="fa-solid fa-gauge-high"></i> My Dashboard
        </a>
        <a href="/logout" class="block mx-6 my-4 py-4 bg-red-600 text-white font-black text-center rounded-xl shadow-lg shadow-red-100 flex items-center justify-center gap-2">
          <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
      <% } else { %>
        <a href="/login" class="block px-6 py-4 text-blue-600 font-semibold">Client Login</a>
      <% } %>
    </div>

</header>