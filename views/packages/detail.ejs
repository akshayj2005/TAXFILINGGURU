<%# Universal DB-driven package registration page — old two-column format %>
<%
  const isNri       = pkg.type === 'nri';
  const isGlobal    = pkg.type === 'global' || pkg.type === 'global-services';
  const isResident  = pkg.type === 'resident';
  const showCountry = true; // Always show now
  const showPan     = !isNri || isGlobal;  // Resident + Global show PAN; pure NRI hide it
  const displayPrice = (() => {
    const p = String(pkg.price);
    if (p === 'Custom' || p.includes('–') || p.includes('-')) return p;
    return '₹' + p;
  })();
  const displayRate = pkg.priceSuffix ? `${displayPrice} ${pkg.priceSuffix}` : displayPrice;
  // Back link: each type returns to its listing page
  const backMap = { resident: '/individualpackage', nri: '/nri', global: '/individualpackage', 'global-services': '/' };
  const backTextMap = { resident: '← Back to Resident Packages', nri: '← Back to NRI Packages', global: '← Back to Packages', 'global-services': '← Back to Services' };
  const backUrl  = backMap[pkg.type]  || '/';
  const backText = backTextMap[pkg.type] || '← Back';
  const loginUrl = isNri ? '/login?type=nri' : '/login?type=resident';
  const bgImage = isNri ? 'pamphlet-nri.jpg' : 'pamphlet-resident.jpg';
%>

<!-- ══ HERO ════════════════════════════════════════════════════════ -->
<section class="w-full hero-bg py-10 px-4 relative flex flex-col justify-center">
    <div class="max-w-7xl mx-auto relative z-10 text-center w-full">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-4"><%= pkg.name %></h2>
        <p class="text-gray-200"><%= pkg.shortDescription || pkg.subheading %></p>
    </div>
</section>

<!-- ══ MAIN ═════════════════════════════════════════════════════════ -->
<main class="w-full py-10 md:py-20 px-4 bg-gray-50">
    <div class="max-w-7xl mx-auto">

        <div class="bg-white rounded-2xl shadow-lg overflow-hidden grid md:grid-cols-2">

            <!-- LEFT PANEL — package info card on blurred background -->
            <div class="relative flex items-center justify-center min-h-[550px] md:min-h-full overflow-hidden p-4 md:p-12">
                <div class="absolute inset-0 z-0">
                    <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 scale-105"
                        style="background-image: url('/assets/images/<%= bgImage %>'); filter: blur(6px);">
                    </div>
                    <div class="absolute inset-0 bg-black/15"></div>
                </div>

                <div class="relative z-10 bg-white/95 backdrop-blur-sm rounded-2xl shadow-2xl p-4 py-8 md:p-8 w-[95%] md:w-[90%] max-w-lg border border-white/20">
                    <% if (pkg.badge) { %>
                    <div class="inline-block <%= pkg.badgeClass || 'bg-blue-100 text-blue-600' %> font-bold px-3 py-1 rounded-full text-xs mb-4 tracking-wide">
                        <%= pkg.badge %>
                    </div>
                    <% } %>

                    <h3 class="text-3xl md:text-4xl font-black tracking-tight mb-2 text-gray-900"><%= pkg.name %></h3>

                    <% if (pkg.subheading) { %>
                        <p class="text-base text-gray-500 mb-1"><%= pkg.subheading %></p>
                    <% } %>

                    <p class="text-gray-600 text-lg mb-5 leading-relaxed border-b border-gray-200 pb-4">
                        <%= pkg.shortDescription || pkg.subheading %>
                    </p>

                    <!-- Features list -->
                    <ul class="space-y-3">
                        <% pkg.features.forEach(function(feat) { %>
                        <li class="flex items-start text-gray-800 text-base font-semibold">
                            <svg class="w-6 h-6 text-green-500 mr-2 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            <%= feat %>
                        </li>
                        <% }); %>
                    </ul>

                    <% if (pkg.bestFor) { %>
                        <p class="mt-4 text-xs text-gray-400 italic">Best for: <%= pkg.bestFor %></p>
                    <% } %>
                </div>
            </div>

            <!-- RIGHT PANEL — registration form -->
            <div class="p-8 md:p-14 bg-white flex flex-col justify-center">
                <div class="max-w-md mx-auto w-full">
                    <div class="mb-10 text-center">
                        <h3 class="text-3xl font-bold text-gray-900 mb-2 font-heading">Provide Your Details</h3>
                        <p class="text-gray-500 text-sm">Fill in the information below to secure your package.</p>
                    </div>

                    <form id="regForm" novalidate class="space-y-4"
                        data-plan-name="<%= pkg.name %>"
                        data-plan-rate="<%= displayRate %>"
                        data-plan-slug="<%= pkg.slug %>"
                        data-is-nri="<%= isNri %>">

