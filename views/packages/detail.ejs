                        <div id="regError" class="hidden text-red-600 text-sm bg-red-50 border border-red-100 rounded-xl px-5 py-3 font-medium"></div>

                        <!-- Terms -->
                        <label class="flex items-start gap-3 text-sm text-gray-500 cursor-pointer group mt-4">
                            <input type="checkbox" id="reg-terms" required class="mt-1 w-5 h-5 rounded-lg border-gray-300 text-blue-600 focus:ring-blue-500 transition-colors">
                            <span class="leading-relaxed">I agree to the <a href="/terms" class="text-blue-600 font-semibold hover:underline">Terms</a> &amp; <a href="/privacy" class="text-blue-600 font-semibold hover:underline">Privacy Policy</a></span>
                        </label>

                        <!-- Submit -->
                        <button type="submit" id="regSubmitBtn" style="background: #2563eb;" disabled
                            class="w-full py-5 text-white font-extrabold text-lg rounded-2xl shadow-xl shadow-blue-200/50 transition-all active:scale-[0.98] hover:opacity-90 hover:-translate-y-1 mt-4 disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none">
                            File Your Tax Now
                        </button>

                        <p class="text-center text-sm text-gray-400 font-medium mt-4">
                            Already Registered?
                            <a href="<%= loginUrl %>" class="text-blue-600 font-bold hover:underline">Log in</a>
                        </p>
                    </form>
                </div>
            </div>
        </div>

        <!-- Back Link -->
        <div class="mt-12 text-center">
            <a href="<%= backUrl %>"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-white border border-gray-200 text-gray-600 font-bold text-sm shadow-sm hover:shadow-md hover:border-blue-400 hover:text-blue-600 transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                <%= backText %>
            </a>
        </div>
    </div>
</main>

<!-- ══ SCRIPT ══════════════════════════════════════════════════════ -->
<script>
(function () {
    const form = document.getElementById('regForm');
    const btn  = document.getElementById('regSubmitBtn');
    const err  = document.getElementById('regError');

    const isNri    = form.dataset.isNri === 'true';
    const planName = form.dataset.planName;
    const planRate = form.dataset.planRate;
    const planSlug = form.dataset.planSlug;

    function showErr(msg) {
        Swal.fire('Notice', msg, 'warning');
        btn.disabled = false;
        btn.textContent = 'File Your Tax Now';
    }

    // Toggle button state based on terms checkbox
    const termsCheckbox = document.getElementById('reg-terms');
    if (termsCheckbox) {
        termsCheckbox.addEventListener('change', function() {
            btn.disabled = !this.checked;
        });
    }

    form.addEventListener('submit', async function (e) {
        e.preventDefault();
        err.classList.add('hidden');
        btn.disabled = true;
        btn.textContent = 'Processing...';

        const name    = document.getElementById('reg-name').value.trim();
        const email   = document.getElementById('reg-email').value.trim();
        let phone   = document.getElementById('reg-phone').value.trim();
        if (document.getElementById('reg-phone-code')) {
            phone = document.getElementById('reg-phone-code').value + phone;
        }
        const pan     = (document.getElementById('reg-pan') || {value:''}).value.trim();
        const message = document.getElementById('reg-message').value.trim();
        const terms   = document.getElementById('reg-terms').checked;
        let country = document.getElementById('reg-country') ? document.getElementById('reg-country').value.trim() : '';
        if (!country) return showErr('Please select your country of residence.');

        if (!name)  return showErr('Please enter your full name.');
        if (!email || !/\S+@\S+\.\S+/.test(email)) return showErr('Please enter a valid email address.');
        
        let validPhone = false;
        let pNum = document.getElementById('reg-phone').value.trim();
        if (pNum) {
            validPhone = (pNum.replace(/\D/g, '').length >= 5);
        }
        if (!validPhone) return showErr('Please enter a valid phone number.');
        
        if (pan && !/^[A-Z]{5}[0-9]{4}[A-Z]{1}$/i.test(pan)) return showErr('Please enter a valid PAN number.');
        if (!terms) return showErr('Please agree to the Terms & Privacy Policy.');

        const { isConfirmed } = await Swal.fire({
            title: 'Confirm Registration',
            html: `✅ Registration ready!<br><br><b>Package:</b> ${planName}<br><b>Price:</b> ${planRate}<br><br>Click Cancel to go back.`,
            icon: 'info',
            showCancelButton: true,
            confirmButtonText: 'Yes, Confirm'
        });
        if (!isConfirmed) {
            btn.disabled = false;
            btn.textContent = 'File Your Tax Now';
            return;
        }

        try {
            const res = await fetch('/api/register-package', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, email, phone, pan, message, planName, planRate, planSlug, isNri, country })
            });
            const data = await res.json();
            if (!data.success) return showErr('Registration failed: ' + (data.error || 'Unknown error'));
            
            if (data.redirectUrl) {
                await Swal.fire('Success', '🎉 Registration successful! Redirecting to payment...', 'success');
                window.location.href = data.redirectUrl;
            } else {
                await Swal.fire('Success', '🎉 Registration successful! You will be redirected to login.', 'success');
                window.location.href = isNri ? '/login?type=nri' : '/login?type=resident';
            }
        } catch (e) {
            return showErr('Could not connect to server. Please try again.');
        }
    });
})();

(function() {
    // Restore user country if they are logged in since we missed dynamically putting `selected` in EJS
    const savedCountry = "<%= locals.user && locals.user.residenceCountry ? user.residenceCountry : '' %>";
    const css = document.getElementById('reg-country');
    if (savedCountry && css && css.tagName === 'SELECT') {
        css.value = savedCountry;
    }

    const cc = document.getElementById('reg-phone-code');
    if (!cc) return;

    function sync(n) {
        for (var i = 0; i < cc.options.length; i++) {
            if (cc.options[i].getAttribute('data-country') === n) {
                cc.selectedIndex = i;
                return;
            }
        }
    }

    if (css) {
        css.addEventListener('change', function() { sync(this.value); });
        if(css.value) sync(css.value); // Sync initial
    }

    fetch('https://ipapi.co/json/')
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (!d.country_name) return;
            // set country code
            sync(d.country_name);
            
            // if we have a select dropdown for country, update it too
            if (css && (!css.value || css.value === '')) {
                if (css.tagName === 'SELECT') {
                    for (var i = 0; i < css.options.length; i++) {
                        if (css.options[i].value === d.country_name) {
                            css.value = d.country_name;
                            break;
                        }
                    }
                } else if (css.tagName === 'INPUT') {
                    css.value = d.country_name;
                }
            }
        })
        .catch(function() {});
})();
</script>