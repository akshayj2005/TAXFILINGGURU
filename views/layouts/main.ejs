                <script>
                    document.addEventListener("DOMContentLoaded", () => {
                        const vcCountry = document.getElementById("vcClientCountry");
                        const vcPhoneCode = document.getElementById("vcClientPhoneCode");
                        if (vcCountry && vcPhoneCode) {
                            vcCountry.addEventListener("change", function () {
                                const cName = this.value;
                                const opt = Array.from(vcPhoneCode.options).find(o => o.getAttribute("data-country") === cName);
                                if (opt) vcPhoneCode.value = opt.value;
                            });
                            
                            // Try to initialize from IP API if not selected
                            if (!vcCountry.value || vcCountry.value === 'India') {
                                fetch('https://ipapi.co/json/')
                                .then(r => r.json())
                                .then(d => {
                                    if (d && d.country_name) {
                                        for (let i = 0; i < vcCountry.options.length; i++) {
                                            if (vcCountry.options[i].value === d.country_name) {
                                                vcCountry.value = d.country_name;
                                                // Trigger change to sync phone code
                                                vcCountry.dispatchEvent(new Event('change'));
                                                break;
                                            }
                                        }
                                    }
                                }).catch(() => {});
                            }
                        }
                    });
                </script>

                <!-- Custom Popup -->
                <%- include('../partials/popup') %>
                
                <!-- Testimonial Modal -->
                <%- include('../partials/testimonial-modal') %>
    </body>

</html>