<section class="w-full hero-bg py-20 px-4 relative flex flex-col justify-center min-h-[40vh]">
  <div class="max-w-7xl mx-auto relative z-10 text-center w-full">
    <div class="flex justify-center mb-6">
      <span class="bg-white/20 backdrop-blur-md text-white px-4 py-1.5 rounded-full text-sm font-semibold tracking-wide border border-white/30 uppercase">
        Smart Financial Tools
      </span>
    </div>
    <h1 class="font-heading text-5xl md:text-7xl font-extrabold text-white mb-6 tracking-tight drop-shadow-lg">
      <%= seo.headings.h1 %>
    </h1>

    <p class="text-xl text-blue-50 max-w-2xl mx-auto font-light leading-relaxed">
      <%= seo.description %>
    </p>
  </div>
  
  <!-- Wave Divider -->
  <div class="wave-divider">
    <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
      <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V46.35C50.62,54.91,105.48,63.07,161.16,64.74,213,66.3,266.3,62.72,321.39,56.44Z" fill="#FFFFFF" fill-opacity="1"></path>
    </svg>
  </div>
</section>

<div class="max-w-7xl mx-auto py-24 px-4">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">

    <!-- Tool 1: Regime Comparison -->
    <div class="group bg-white p-10 rounded-[2.5rem] shadow-[0_10px_40px_-15px_rgba(0,0,0,0.1)] border border-gray-100 hover:shadow-[0_20px_50px_-12px_rgba(59,130,246,0.2)] transition-all duration-500 flex flex-col h-full relative overflow-hidden">
      <div class="absolute top-0 right-0 w-24 h-24 bg-blue-50 rounded-bl-[100px] -mr-12 -mt-12 transition-all duration-500 group-hover:bg-blue-100"></div>
      
      <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center text-2xl mb-8 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
        <i class="fa-solid fa-calculator text-blue-600"></i>
      </div>
      
      <h3 class="text-2xl font-bold text-gray-900 mb-4 tracking-tight">Regime Comparison</h3>
      <p class="text-gray-600 mb-8 flex-grow leading-relaxed">
        Compare Old vs New (FY 24-25 & 25-26) tax liability in seconds. Includes Budget 2025 updates and smart optimization tips.
      </p>
      
      <a href="/regime-comparison" class="inline-flex items-center group/btn overflow-hidden relative bg-blue-50 hover:bg-blue-600 text-blue-600 hover:text-white font-bold py-4 px-6 rounded-2xl transition-all duration-300 w-full justify-center">
        <span class="relative z-10 flex items-center">
          Launch Comparison Tool
          <i class="fa-solid fa-arrow-right ml-3 group-hover/btn:translate-x-1 transition-transform"></i>
        </span>
      </a>
    </div>

    <!-- Tool 2: Refund Maximizer -->
    <div class="group bg-white p-10 rounded-[2.5rem] shadow-[0_10px_40px_-15px_rgba(0,0,0,0.1)] border border-gray-100 hover:shadow-[0_20px_50px_-12px_rgba(22,163,74,0.2)] transition-all duration-500 flex flex-col h-full relative overflow-hidden">
      <div class="absolute top-0 right-0 w-24 h-24 bg-green-50 rounded-bl-[100px] -mr-12 -mt-12 transition-all duration-500 group-hover:bg-green-100"></div>
      
      <div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center text-2xl mb-8 group-hover:scale-110 group-hover:-rotate-3 transition-all duration-500">
        <i class="fa-solid fa-sack-dollar text-green-600"></i>
      </div>
      
      <h3 class="text-2xl font-bold text-gray-900 mb-4 tracking-tight">Refund Maximizer</h3>
      <p class="text-gray-600 mb-8 flex-grow leading-relaxed">
        A smart checklist to find every tax deduction you missed. Scans 80C, 80D, HRA, and specialized investment sections.
      </p>
      
      <a href="/refund-maximizer" class="inline-flex items-center group/btn overflow-hidden relative bg-green-50 hover:bg-green-600 text-green-600 hover:text-white font-bold py-4 px-6 rounded-2xl transition-all duration-300 w-full justify-center">
        <span class="relative z-10 flex items-center">
          Find Your Savings
          <i class="fa-solid fa-arrow-right ml-3 group-hover/btn:translate-x-1 transition-transform"></i>
        </span>
      </a>
    </div>

    <!-- Tool 3: NRI Status Tracker -->
    <div class="group bg-white p-10 rounded-[2.5rem] shadow-[0_10px_40px_-15px_rgba(0,0,0,0.1)] border border-gray-100 hover:shadow-[0_20px_50px_-12px_rgba(249,115,22,0.2)] transition-all duration-500 flex flex-col h-full relative overflow-hidden">
      <div class="absolute top-0 right-0 w-24 h-24 bg-orange-50 rounded-bl-[100px] -mr-12 -mt-12 transition-all duration-500 group-hover:bg-orange-100"></div>
      
      <div class="w-16 h-16 bg-orange-100 rounded-2xl flex items-center justify-center text-2xl mb-8 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
        <i class="fa-solid fa-plane-departure text-orange-600"></i>
      </div>
      
      <h3 class="text-2xl font-bold text-gray-900 mb-4 tracking-tight">NRI Status Tracker</h3>
      <p class="text-gray-600 mb-8 flex-grow leading-relaxed">
        Determines your residential status precisely based on days spent in India for current and past 10 years.
      </p>
      
      <a href="/nri-status" class="inline-flex items-center group/btn overflow-hidden relative bg-orange-50 hover:bg-orange-600 text-orange-600 hover:text-white font-bold py-4 px-6 rounded-2xl transition-all duration-300 w-full justify-center">
        <span class="relative z-10 flex items-center">
          Check Residency
          <i class="fa-solid fa-arrow-right ml-3 group-hover/btn:translate-x-1 transition-transform"></i>
        </span>
      </a>
    </div>

    <!-- Tool 4: Trader Turnover -->
    <div class="group bg-white p-10 rounded-[2.5rem] shadow-[0_10px_40px_-15px_rgba(0,0,0,0.1)] border border-gray-100 hover:shadow-[0_20px_50px_-12px_rgba(147,51,234,0.2)] transition-all duration-500 flex flex-col h-full relative overflow-hidden">
      <div class="absolute top-0 right-0 w-24 h-24 bg-purple-50 rounded-bl-[100px] -mr-12 -mt-12 transition-all duration-500 group-hover:bg-purple-100"></div>
      
      <div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center text-2xl mb-8 group-hover:scale-110 group-hover:-rotate-3 transition-all duration-500">
        <i class="fa-solid fa-chart-line text-purple-600"></i>
      </div>
      
      <h3 class="text-2xl font-bold text-gray-900 mb-4 tracking-tight">Trader Turnover</h3>
      <p class="text-gray-600 mb-8 flex-grow leading-relaxed">
        Calculate absolute turnover for F&O and Intraday trades. Instantly check if you need a tax audit for this financial year.
      </p>
      
      <a href="/trader-turnover" class="inline-flex items-center group/btn overflow-hidden relative bg-purple-50 hover:bg-purple-600 text-purple-600 hover:text-white font-bold py-4 px-6 rounded-2xl transition-all duration-300 w-full justify-center">
        <span class="relative z-10 flex items-center">
          Calculate Turnover
          <i class="fa-solid fa-arrow-right ml-3 group-hover/btn:translate-x-1 transition-transform"></i>
        </span>
      </a>
    </div>

    <!-- Tool 5: Refund Status -->
    <div class="group bg-white p-10 rounded-[2.5rem] shadow-[0_10px_40px_-15px_rgba(0,0,0,0.1)] border border-gray-100 hover:shadow-[0_20px_50px_-12px_rgba(236,72,153,0.2)] transition-all duration-500 flex flex-col h-full relative overflow-hidden">
      <div class="absolute top-0 right-0 w-24 h-24 bg-pink-50 rounded-bl-[100px] -mr-12 -mt-12 transition-all duration-500 group-hover:bg-pink-100"></div>
      
      <div class="w-16 h-16 bg-pink-100 rounded-2xl flex items-center justify-center text-2xl mb-8 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
        <i class="fa-solid fa-magnifying-glass-dollar text-pink-600"></i>
      </div>
      
      <h3 class="text-2xl font-bold text-gray-900 mb-4 tracking-tight">Refund Status</h3>
      <p class="text-gray-600 mb-8 flex-grow leading-relaxed">
        Track your ITR refund status securely. All you need is your PAN and Assessment Year to get the latest update.
      </p>
      
      <a href="/refund-status" class="inline-flex items-center group/btn overflow-hidden relative bg-pink-50 hover:bg-pink-600 text-pink-600 hover:text-white font-bold py-4 px-6 rounded-2xl transition-all duration-300 w-full justify-center">
        <span class="relative z-10 flex items-center">
          Track Refund
          <i class="fa-solid fa-arrow-right ml-3 group-hover/btn:translate-x-1 transition-transform"></i>
        </span>
      </a>
    </div>

  </div>
</div>