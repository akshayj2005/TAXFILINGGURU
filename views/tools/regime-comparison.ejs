<section class="w-full hero-bg py-20 px-4 relative flex flex-col justify-center min-h-[35vh]">
  <div class="max-w-7xl mx-auto relative z-10 text-center w-full">
    <div class="flex justify-center mb-6">
      <span class="bg-white/20 backdrop-blur-md text-white px-4 py-1.5 rounded-full text-sm font-semibold tracking-wide border border-white/30 uppercase">
        Tax Optimizer
      </span>
    </div>
    <h1 class="font-heading text-5xl md:text-7xl font-extrabold text-white mb-6 tracking-tight drop-shadow-lg">
      <%= seo.headings.h1 %>
    </h1>
    <p class="text-xl text-blue-50 max-w-2xl mx-auto font-light leading-relaxed">
      <%= seo.description %>
    </p>
  </div>
  <!-- Wave Divider -->
  <div class="wave-divider">
    <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
      <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V46.35C50.62,54.91,105.48,63.07,161.16,64.74,213,66.3,266.3,62.72,321.39,56.44Z" fill="#F9FAFB" fill-opacity="1"></path>
    </svg>
  </div>
</section>

<div class="max-w-7xl mx-auto py-16 px-4">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

    <!-- Input Form -->
    <div class="lg:col-span-4 bg-white p-10 rounded-[2.5rem] shadow-[0_10px_40px_-15px_rgba(0,0,0,0.1)] border border-gray-100 flex flex-col h-fit">
      <h3 class="text-2xl font-bold text-gray-900 mb-8 flex items-center">
        <i class="fa-solid fa-pen-to-square text-blue-600 mr-3"></i>
        Enter Details
      </h3>
      <form id="taxForm" class="space-y-6">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">Annual Gross Income (₹)</label>
          <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 font-semibold">₹</span>
            <input type="number" id="income" required placeholder="e.g. 15,00,000"
              class="w-full pl-10 pr-4 py-4 border border-gray-200 rounded-2xl focus:ring-4 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all text-gray-900 font-medium placeholder:text-gray-300">
          </div>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Total Deductions (₹)
            <span class="block text-[10px] text-gray-400 font-normal mt-0.5">(80C, 80D, etc. - for Old Regime)</span>
          </label>
          <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 font-semibold">₹</span>
            <input type="number" id="deductions" value="0"
              class="w-full pl-10 pr-4 py-4 border border-gray-200 rounded-2xl focus:ring-4 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all text-gray-900 font-medium">
          </div>
        </div>
        <button type="submit"
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-5 rounded-2xl transition-all shadow-xl shadow-blue-100 flex items-center justify-center group">
          Calculate Optimization
          <i class="fa-solid fa-sparkles ml-3 group-hover:rotate-12 transition-transform"></i>
        </button>
      </form>
    </div>

    <!-- Results Display -->
    <div class="lg:col-span-8 space-y-10">
      <div id="results" class="hidden grid grid-cols-1 md:grid-cols-3 gap-6 animate-[fadeInUp_0.6s_ease-out]">

        <!-- Old Regime -->
        <div class="group bg-white p-6 rounded-3xl border border-gray-100 shadow-sm hover:shadow-md transition-all">
          <div class="flex items-center justify-between mb-4">
            <h4 class="text-gray-400 font-bold text-xs uppercase tracking-widest">Old Regime</h4>
            <i class="fa-solid fa-landmark text-gray-200 group-hover:text-gray-400 transition-colors"></i>
          </div>
          <p class="text-3xl font-black text-gray-800" id="tax-old">₹0</p>
          <div class="mt-6 pt-4 border-t border-gray-50 space-y-2">
            <div class="flex justify-between text-xs">
              <span class="text-gray-400">Taxable:</span>
              <span class="text-gray-600 font-bold" id="taxable-old">₹0</span>
            </div>
            <div class="flex justify-between text-xs">
              <span class="text-gray-400">Deductions:</span>
              <span class="text-gray-600 font-bold" id="ded-old">₹0</span>
            </div>
          </div>
        </div>

        <!-- New Regime FY 24-25 -->
        <div class="group bg-white p-6 rounded-3xl border border-blue-50 shadow-sm hover:shadow-md transition-all">
          <div class="flex items-center justify-between mb-4">
            <h4 class="text-blue-500 font-bold text-xs uppercase tracking-widest">New (FY 24-25)</h4>
            <i class="fa-solid fa-calendar-days text-blue-100 group-hover:text-blue-200 transition-colors"></i>
          </div>
          <p class="text-3xl font-black text-gray-800" id="tax-24">₹0</p>
          <div class="mt-6 pt-4 border-t border-gray-50 space-y-2">
            <div class="flex justify-between text-xs">
              <span class="text-gray-400">Taxable:</span>
              <span class="text-blue-600 font-bold" id="taxable-24">₹0</span>
            </div>
            <div class="flex justify-between text-xs">
              <span class="text-gray-400">Std. Ded:</span>
              <span class="text-gray-600 font-bold">₹75,000</span>
            </div>
          </div>
        </div>

        <!-- New Regime FY 25-26 -->
        <div class="group bg-green-50/50 backdrop-blur-sm p-6 rounded-[2rem] border-2 border-green-500 shadow-xl shadow-green-100 transform md:scale-110 relative overflow-hidden transition-all duration-500 hover:scale-[1.12]">
          <div class="absolute top-0 right-0 p-3">
             <span class="bg-green-500 text-white text-[10px] px-3 py-1 rounded-full font-black tracking-widest uppercase">Latest</span>
          </div>
          <div class="flex items-center space-x-2 mb-4">
            <i class="fa-solid fa-star text-green-500 text-xs"></i>
            <h4 class="text-green-700 font-black text-xs uppercase tracking-widest">New (FY 25-26)</h4>
          </div>
          <p class="text-4xl font-black text-green-600" id="tax-25">₹0</p>
          <div class="mt-6 pt-4 border-t border-green-200/50 space-y-2">
            <div class="flex justify-between text-xs">
              <span class="text-green-700/60 uppercase font-black tracking-tighter">Taxable Income</span>
              <span class="text-green-800 font-black" id="taxable-25">₹0</span>
            </div>
            <div class="flex justify-between text-xs">
              <span class="text-green-700/60 uppercase font-black tracking-tighter">Standard Ded.</span>
              <span class="text-green-800 font-black">₹75,000</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Placeholder -->
      <div id="placeholder"
        class="h-80 flex flex-col items-center justify-center bg-white rounded-[2.5rem] border-2 border-dashed border-gray-200 group hover:border-blue-300 transition-colors">
        <div class="w-16 h-16 bg-gray-50 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <i class="fa-solid fa-chart-pie text-gray-300 group-hover:text-blue-400 transition-colors text-2xl"></i>
        </div>
        <p class="text-gray-400 font-medium italic">Enter your income details to generate comparison</p>
      </div>

      <!-- Comparison Table -->
      <div id="table-container" class="hidden bg-white rounded-[2rem] shadow-xl border border-gray-50 overflow-hidden animate-[fadeInUp_0.8s_ease-out]">
         <div class="p-6 border-b border-gray-50 bg-gray-50/50">
            <h4 class="text-lg font-bold text-gray-800">Detailed Breakdown</h4>
         </div>
         <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="bg-gray-50">
                <th class="p-6 font-bold text-gray-500 text-xs uppercase tracking-widest">Particulars</th>
                <th class="p-6 font-bold text-gray-500 text-xs uppercase tracking-widest">Old Regime</th>
                <th class="p-6 font-bold text-green-600 text-xs uppercase tracking-widest">New (25-26)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="p-6 text-sm font-medium text-gray-700">Standard Deduction</td>
                <td class="p-6 text-sm text-gray-600">₹50,000</td>
                <td class="p-6 text-sm text-green-700 font-bold">₹75,000</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="p-6 text-sm font-medium text-gray-700">Base Tax Amount</td>
                <td class="p-6 text-sm text-gray-600 font-medium" id="base-old">₹0</td>
                <td class="p-6 text-sm text-green-700 font-bold" id="base-25">₹0</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="p-6 text-sm font-medium text-gray-700">Health & Edu Cess (4%)</td>
                <td class="p-6 text-sm text-gray-600 font-medium" id="cess-old">₹0</td>
                <td class="p-6 text-sm text-green-700 font-bold" id="cess-25">₹0</td>
              </tr>
              <tr class="bg-green-600 text-white">
                <td class="p-6 font-black text-lg">Total Tax Payable</td>
                <td class="p-6 font-black text-lg" id="total-old">₹0</td>
                <td class="p-6 font-black text-2xl" id="total-25">₹0</td>
              </tr>
            </tbody>
          </table>
         </div>
      </div>

    </div>
  </div>
</div>