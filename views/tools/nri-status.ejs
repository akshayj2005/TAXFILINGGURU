<section class="w-full hero-bg py-20 px-4 relative flex flex-col justify-center min-h-[35vh]">
  <div class="max-w-7xl mx-auto relative z-10 text-center w-full">
    <div class="flex justify-center mb-6">
      <span class="bg-white/20 backdrop-blur-md text-white px-4 py-1.5 rounded-full text-sm font-semibold tracking-wide border border-white/30 uppercase">
        Residential Status Advisor
      </span>
    </div>
    <h1 class="font-heading text-5xl md:text-7xl font-extrabold text-white mb-6 tracking-tight drop-shadow-lg">
      NRI Status <span class="text-blue-200">Tracker</span>
    </h1>
    <p class="text-xl text-blue-50 max-w-2xl mx-auto font-light leading-relaxed">
      Determine your exact residential status for Indian Income Tax purposes based on your physical presence.
    </p>
  </div>
  <!-- Wave Divider -->
  <div class="wave-divider">
    <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
      <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V46.35C50.62,54.91,105.48,63.07,161.16,64.74,213,66.3,266.3,62.72,321.39,56.44Z" fill="#F9FAFB" fill-opacity="1"></path>
    </svg>
  </div>
</section>

<div class="max-w-4xl mx-auto py-16 px-4">
  <div class="bg-white rounded-[2.5rem] shadow-[0_20px_50px_-12px_rgba(0,0,0,0.08)] overflow-hidden border border-gray-100 p-10 md:p-16 relative">
    <div class="absolute top-0 right-0 p-8 opacity-5">
        <i class="fa-solid fa-passport text-9xl"></i>
    </div>
    
    <form id="nriForm" class="space-y-8 relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wider">Days in India (Current FY)</label>
          <div class="relative group">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-500 transition-colors">
              <i class="fa-solid fa-calendar-day"></i>
            </span>
            <input type="number" id="daysInIndia" required placeholder="e.g. 45"
              class="w-full pl-12 pr-4 py-4 border border-gray-200 rounded-2xl focus:ring-4 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all text-gray-900 font-medium placeholder:text-gray-300">
          </div>
          <p class="text-[10px] text-gray-400 mt-2 font-medium">April 1st to March 31st of current year</p>
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 mb-3 uppercase tracking-wider">Days in India (Past 4 FYs)</label>
          <div class="relative group">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-500 transition-colors">
              <i class="fa-solid fa-calendar-days"></i>
            </span>
            <input type="number" id="daysInIndiaPast4Years" required placeholder="e.g. 300"
              class="w-full pl-12 pr-4 py-4 border border-gray-200 rounded-2xl focus:ring-4 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all text-gray-900 font-medium placeholder:text-gray-300">
          </div>
           <p class="text-[10px] text-gray-400 mt-2 font-medium">Total aggregate stay in preceding 4 years</p>
        </div>
      </div>

      <div class="space-y-4 pt-4">
        <div class="flex items-center group cursor-pointer">
          <label class="relative flex items-center cursor-pointer select-none">
            <input type="checkbox" id="isIndianCitizen" checked
              class="sr-only peer">
            <div class="w-12 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600 transition-colors"></div>
            <span class="ml-4 text-gray-700 font-bold text-sm">I am an Indian Citizen or Person of Indian Origin (PIO)</span>
          </label>
        </div>

        <div class="flex items-center group cursor-pointer">
          <label class="relative flex items-center cursor-pointer select-none">
            <input type="checkbox" id="incomeInIndiaExceeds15L"
              class="sr-only peer">
            <div class="w-12 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600 transition-colors"></div>
            <span class="ml-4 text-gray-700 font-bold text-sm">My total Indian income exceeds ₹15 Lakhs</span>
          </label>
        </div>
      </div>

      <button type="submit"
        class="w-full bg-green-400 hover:bg-green-500 text-white font-black py-5 rounded-2xl transition-all shadow-xl shadow-green flex items-center justify-center group overflow-hidden relative">
        <span class="relative z-10 flex items-center">
            Check Residential Status
            <i class="fa-solid fa-magnifying-glass-location ml-3 group-hover:scale-110 transition-transform"></i>
        </span>
      </button>
    </form>

    <div id="result" class="hidden mt-12 p-8 bg-blue-50/50 backdrop-blur-sm rounded-[2rem] border-2 border-dashed border-blue-200 text-center animate-[fadeInUp_0.5s_ease-out]">
      <p class="text-blue-400 font-black text-xs uppercase tracking-[0.2em] mb-4">Final Determination</p>
      <h3 class="text-4xl font-black text-blue-900 leading-tight mb-4" id="statusText">Pending Analysis...</h3>
      <div class="flex justify-center items-center space-x-2 text-gray-400 text-[10px] font-bold uppercase tracking-widest bg-white/50 py-2 px-4 rounded-full w-fit mx-auto">
         <i class="fa-solid fa-gavel"></i>
         <span>Income Tax Act, 1961 - Section 6</span>
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('nriForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const daysInIndia = document.getElementById('daysInIndia').value;
    const daysInIndiaPast4Years = document.getElementById('daysInIndiaPast4Years').value;
    const isIndianCitizen = document.getElementById('isIndianCitizen').checked;
    const incomeInIndiaExceeds15L = document.getElementById('incomeInIndiaExceeds15L').checked;

    const response = await fetch('/api/calculate-nri-status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ daysInIndia, daysInIndiaPast4Years, isIndianCitizen, incomeInIndiaExceeds15L })
    });

    const data = await response.json();

    if (data.status) {
      document.getElementById('result').classList.remove('hidden');
      document.getElementById('statusText').innerText = data.status;

      // Dynamic Styling based on result
      const resultBox = document.getElementById('result');
      const statusText = document.getElementById('statusText');

      if (data.status.includes('Non-Resident')) {
        resultBox.className = "mt-12 p-8 bg-green-50/50 backdrop-blur-sm rounded-[2rem] border-2 border-green-200 text-center animate-[fadeInUp_0.5s_ease-out]";
        statusText.className = "text-4xl font-black text-green-700 leading-tight mb-4";
      } else if (data.status.includes('RNOR')) {
        resultBox.className = "mt-12 p-8 bg-orange-50/50 backdrop-blur-sm rounded-[2rem] border-2 border-orange-200 text-center animate-[fadeInUp_0.5s_ease-out]";
        statusText.className = "text-4xl font-black text-orange-700 leading-tight mb-4";
      } else {
        resultBox.className = "mt-12 p-8 bg-blue-50/50 backdrop-blur-sm rounded-[2rem] border-2 border-blue-200 text-center animate-[fadeInUp_0.5s_ease-out]";
        statusText.className = "text-4xl font-black text-blue-900 leading-tight mb-4";
      }
    } else {
      showPopup({ title: 'Calculation Failed', message: 'Something went wrong. Please check your inputs.', type: 'error' });
    }
  });
</script>