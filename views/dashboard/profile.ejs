<%- contentFor('body') %>

<div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
        <a href="/dashboard" class="text-blue-600 hover:text-blue-800 font-bold flex items-center gap-2 transition-all">
            <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <div class="bg-white shadow-2xl rounded-3xl overflow-hidden border border-gray-100">
        <div class="bg-gradient-to-r from-blue-600 to-indigo-700 px-8 py-10 sm:px-12 text-white relative">
            <div class="flex flex-col md:flex-row items-center gap-8">
                <div class="group relative">
                    <div id="profileImageContainer" class="w-32 h-32 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center text-5xl font-black border-4 border-white/30 shadow-2xl overflow-hidden cursor-pointer" onclick="document.getElementById('profileImageInput').click()">
                        <% if (user.profileImage) { %>
                            <img src="<%= user.profileImage %>" alt="Profile" class="w-full h-full object-cover">
                        <% } else { %>
                            <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.name || 'User') %>&background=random&color=fff&bold=true" alt="Profile" class="w-full h-full object-cover">
                        <% } %>
                        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                            <i class="fa-solid fa-camera text-2xl"></i>
                        </div>
                    </div>
                    <input type="file" id="profileImageInput" class="hidden" accept="image/*" onchange="uploadProfileImage(event)">
                    
                    <% if (user.profileImage) { %>
                        <button onclick="deleteProfileImage()" class="absolute -bottom-2 -right-2 w-10 h-10 bg-red-600 text-white rounded-full border-4 border-white flex items-center justify-center hover:bg-red-700 transition-all shadow-lg" title="Delete Photo">
                            <i class="fa-solid fa-trash-can text-sm"></i>
                        </button>
                    <% } %>
                </div>
                <div class="text-center md:text-left">
                    <h1 class="text-4xl font-black tracking-tight"><%= user.name %></h1>
                    <p class="text-blue-100 mt-1 opacity-90 text-lg"><%= user.email %></p>
                    <div class="mt-3 flex gap-2">
                        <span class="px-3 py-1 bg-white/20 rounded-full text-[10px] font-bold uppercase tracking-widest border border-white/20">
                            <%= user.type %> Account
                        </span>
                        <% if (user.isEmailVerified) { %>
                            <span class="px-3 py-1 bg-green-500/20 rounded-full text-[10px] font-bold uppercase tracking-widest border border-green-500/30 text-green-100">
                                <i class="fa-solid fa-check-circle"></i> Verified
                            </span>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="px-8 py-10 sm:px-12 bg-white">
            <form id="profileForm" class="space-y-8">
                <!-- Personal Information -->
                <div>
                    <h2 class="text-xl font-black text-gray-900 mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-id-card text-blue-600 font-normal"></i> Personal Information
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-gray-400 uppercase tracking-widest">Full Name</label>
                            <input type="text" name="name" value="<%= user.name %>" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all font-medium">
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-gray-400 uppercase tracking-widest">Phone Number</label>
                            <div class="flex gap-2">
                                <select id="profilePhoneCode" class="w-24 px-2 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all font-medium text-sm">
                                    <optgroup label="Country Code">
                                        <option value="+91">+91</option>
                                        <option value="+1">+1</option>
                                        <option value="+44">+44</option>
                                        <option value="+971">+971</option>
                                        <option value="+61">+61</option>
                                        <option value="+81">+81</option>
                                        <option value="+65">+65</option>
                                        <option value="+49">+49</option>
                                        <option value="+33">+33</option>
                                        <!-- Add more as needed or use a full list -->
                                    </optgroup>
                                </select>
                                <input type="tel" id="profilePhone" placeholder="1234567890" value="" class="flex-1 px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all font-medium">
                                <input type="hidden" name="phone" id="finalPhone">
                            </div>
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-gray-400 uppercase tracking-widest">PAN Number</label>
                            <input type="text" name="pan" value="<%= user.pan %>" placeholder="ABCDE1234F" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all font-medium uppercase">
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-gray-400 uppercase tracking-widest">Residence Country</label>
                            <input type="text" name="residenceCountry" value="<%= user.residenceCountry %>" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all font-medium">
                        </div>
                    </div>
                </div>

                <hr class="border-gray-100">

                <!-- Security Section -->
                <div>
                    <h2 class="text-xl font-black text-gray-900 mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-shield-halved text-red-600 font-normal"></i> Security & Password
                    </h2>
                    <div class="bg-red-50/50 border border-red-100 rounded-2xl p-6">
                        <p class="text-xs text-red-700 font-bold mb-4 uppercase tracking-wider italic">Leave blank if you don't want to change password</p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="text-xs font-bold text-gray-500 uppercase tracking-widest">Current Password</label>
                                <div class="relative">
                                    <input type="password" name="oldPassword" id="oldPass" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-red-500 outline-none transition-all font-medium pr-12">
                                    <button type="button" onclick="togglePass('oldPass', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 p-2 hover:text-red-600">
                                        <i class="fa-solid fa-eye-slash"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-bold text-gray-500 uppercase tracking-widest">New Password</label>
                                <div class="relative">
                                    <input type="password" name="newPassword" id="newPass" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-green-500 outline-none transition-all font-medium pr-12">
                                    <button type="button" onclick="togglePass('newPass', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 p-2 hover:text-green-600">
                                        <i class="fa-solid fa-eye-slash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-end gap-4 pt-6">
                    <button type="submit" class="px-10 py-4 bg-blue-600 text-white font-black text-lg rounded-2xl hover:bg-blue-700 transition-all shadow-xl shadow-blue-200 flex items-center gap-3">
                        <i class="fa-solid fa-save"></i> Save Profile Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function togglePass(id, btn) {
        const input = document.getElementById(id);
        const icon = btn.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        } else {
            input.type = 'password';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        }
    }

    document.getElementById('profileForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const btn = e.target.querySelector('button[type="submit"]');
        const originalText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Updating...';

        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());

        // Combine phone
        const pCode = document.getElementById('profilePhoneCode').value;
        const pNum = document.getElementById('profilePhone').value.trim();
        if (pNum) {
            data.phone = pCode + pNum;
        } else {
            data.phone = "";
        }

        try {
            const res = await fetch('/api/dashboard/profile', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await res.json();

            if (result.success) {
                Swal.fire({ 
                    title: 'Success', 
                    text: result.message, 
                    icon: 'success',
                    willClose: () => window.location.reload()
                });
            } else {
                throw new Error(result.error);
            }
        } catch (err) {
            Swal.fire({ title: 'Error', text: err.message, icon: 'error' });
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    });

    async function uploadProfileImage(event) {
        const file = event.target.files[0];
        if (!file) return;

        const formData = new FormData();
        formData.append('profileImage', file);

        try {
            Swal.fire({ title: 'Uploading...', text: 'Setting up your new look.', icon: 'info' });
            
            const res = await fetch('/api/dashboard/profile/image', {
                method: 'POST',
                body: formData
            });
            const data = await res.json();
            if (data.success) {
                window.location.reload();
            } else {
                throw new Error(data.error);
            }
        } catch (err) {
            Swal.fire({ title: 'Error', text: err.message, icon: 'error' });
        }
    }

    async function deleteProfileImage() {
        const { isConfirmed } = await Swal.fire({
            title: 'Remove Photo?',
            text: 'Are you sure you want to remove your profile photo?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Yes, remove it!'
        });
        if (!isConfirmed) return;

        try {
            const res = await fetch('/api/dashboard/profile/image', {
                method: 'DELETE'
            });
            const data = await res.json();
            if (data.success) {
                window.location.reload();
            } else {
                throw new Error(data.error);
            }
        } catch (err) {
            Swal.fire({ title: 'Error', text: err.message, icon: 'error' });
        }
    }
    // Fetch IP to set country code if new, or parse from existing
    document.addEventListener('DOMContentLoaded', () => {
        const existingPhone = "<%= user.phone || '' %>";
        const codeSelect = document.getElementById('profilePhoneCode');
        const phoneInput = document.getElementById('profilePhone');
        
        let foundCode = false;
        if (existingPhone.startsWith('+')) {
            // Try to match longest prefix
            const codes = Array.from(codeSelect.options).map(o => o.value).sort((a,b) => b.length - a.length);
            for (const c of codes) {
                if (existingPhone.startsWith(c)) {
                    codeSelect.value = c;
                    phoneInput.value = existingPhone.substring(c.length);
                    foundCode = true;
                    break;
                }
            }
        }
        
        if (!foundCode) {
            phoneInput.value = existingPhone;
            fetch('https://ipapi.co/json/')
                .then(r => r.json())
                .then(d => {
                    if (d && d.country_calling_code) {
                        codeSelect.value = d.country_calling_code;
                    }
                }).catch(() => {});
        }
    });
</script>
