<%- contentFor('body') %>
<div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <% if (user && !user.isEmailVerified) { %>
        <div id="verify-email-banner" class="mb-6 bg-amber-50 border border-amber-200 rounded-2xl p-4 flex flex-col md:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center shrink-0">
                    <i class="fa-solid fa-envelope-circle-check text-lg"></i>
                </div>
                <div>
                    <h4 class="text-amber-900 font-bold text-sm">Verify your email address</h4>
                    <p class="text-amber-700 text-xs mt-0.5">Please verify your email to unlock all features and secure your account.</p>
                </div>
            </div>
            <button onclick="resendVerification()" id="resend-btn" class="px-5 py-2 rounded-lg bg-amber-600 text-white text-xs font-bold hover:bg-amber-700 transition-all shrink-0">
                Resend Verification Link
            </button>
        </div>
        <script>
            async function resendVerification() {
                const btn = document.getElementById('resend-btn');
                const originalText = btn.textContent;
                btn.disabled = true;
                btn.textContent = 'Sending...';
                
                try {
                    const res = await fetch('/api/auth/resend-verification', { method: 'POST' });
                    const data = await res.json();
                    if (data.success) {
                        btn.textContent = 'Sent! Check your inbox';
                        btn.classList.replace('bg-amber-600', 'bg-green-600');
                        
                        // Show Gmail link after sending if it's a Gmail user
                        const email = "<%= user.email %>";
                        if (email.toLowerCase().endsWith('@gmail.com')) {
                            const gmailLink = document.createElement('a');
                            gmailLink.href = "https://mail.google.com/mail/u/0/#search/from%3Asupport%40taxfilingguru.com";
                            gmailLink.target = "_blank";
                            gmailLink.className = "mt-2 md:mt-0 text-xs text-blue-600 font-bold hover:underline flex items-center gap-1";
                            gmailLink.innerHTML = '<i class="fa-solid fa-arrow-up-right-from-square"></i> Open Gmail';
                            btn.parentNode.appendChild(gmailLink);
                        }
                    } else {
                        Swal.fire('Error', data.error || 'Failed to send email', 'error');
                        btn.disabled = false;
                        btn.textContent = originalText;
                    }
                } catch (err) {
                    Swal.fire('Error', 'Server error. Please try again.', 'error');
                    btn.disabled = false;
                    btn.textContent = originalText;
                }
            }
        </script>
    <% } %>

    <div class="bg-white shadow-xl rounded-3xl overflow-hidden border border-gray-100">
        <div class="px-8 py-10 sm:px-12">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10">
                <div class="flex items-center gap-6">
                    <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center text-2xl font-black text-blue-600 border border-blue-200 shadow-inner overflow-hidden">
                        <% if (user.profileImage) { %>
                            <img src="<%= user.profileImage %>" alt="" class="w-full h-full object-cover">
                        <% } else { %>
                            <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.name || 'User') %>&background=random&color=fff&bold=true" alt="Profile" class="w-full h-full object-cover">
                        <% } %>
                    </div>
                    <div>
                        <h1 class="text-3xl font-black text-gray-900 tracking-tight">Welcome, <span class="text-blue-600"><%= user.name %></span>!</h1>
                        <p class="text-gray-500 text-sm mt-1">Manage your tax filings and documents securely.</p>
                    </div>
                </div>
                <div class="flex items-center space-x-3">
                    <button onclick="openTestimonialModal()" class="px-5 py-2 rounded-lg bg-indigo-50 text-indigo-600 text-xs font-bold hover:bg-indigo-600 hover:text-white transition-all shrink-0 border border-indigo-100 flex items-center gap-2">
                        <i class="fa-solid fa-comment-dots"></i> Share Feedback
                    </button>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold <%= user.type === 'nri' ? 'bg-yellow-100 text-yellow-700' : 'bg-blue-100 text-blue-700' %> uppercase tracking-wider">
                        <%= user.type %> Account
                    </span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
                <div class="bg-blue-50 border border-blue-100 rounded-2xl p-6 transition-all hover:shadow-md">
                    <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center mb-4">
                        <i class="fa-solid fa-boxes-stacked text-xl"></i>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900">Active Packages</h3>
                    <p class="text-3xl font-black text-blue-700 mt-2"><%= user.packages.length %></p>
                </div>
                
                <div class="bg-green-50 border border-green-100 rounded-2xl p-6 transition-all hover:shadow-md">
                    <div class="w-12 h-12 bg-green-100 text-green-600 rounded-xl flex items-center justify-center mb-4">
                        <i class="fa-solid fa-receipt text-xl"></i>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900">Payment Status</h3>
                    <div class="flex items-center justify-between mt-2">
                        <p class="text-xl font-bold text-green-700"><%= user.paymentStatus %></p>
                        <% if (user.paymentStatus === 'Completed') { %>
                            <a href="/api/dashboard/invoice" class="text-[10px] font-black underline hover:text-green-900 transition-all uppercase tracking-tighter">
                                <i class="fa-solid fa-file-invoice"></i> Print Tax Receipt
                            </a>
                        <% } %>
                    </div>
                </div>

                <div class="bg-purple-50 border border-purple-100 rounded-2xl p-6 transition-all hover:shadow-md">
                    <div class="w-12 h-12 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center mb-4">
                        <i class="fa-solid fa-calendar-days text-xl"></i>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900">Registered On</h3>
                    <p class="text-xl font-bold text-purple-700 mt-2"><%= new Date(user.createdAt).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %></p>
                </div>
            </div>

            <div class="border-t border-gray-100 pt-10">
                <div class="flex items-center justify-between mb-8">
                    <h2 class="text-2xl font-black text-gray-900">Document Management</h2>
                    <span class="text-xs font-bold text-gray-400 bg-gray-100 px-3 py-1 rounded-full uppercase tracking-tighter">Secure 256-bit Encryption</span>
                </div>

                <!-- Mandatory Documents Section -->
                <div class="mb-10">
                    <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-4 flex items-center">
                        <i class="fa-solid fa-shield-halved mr-2 text-blue-500"></i> Identity Documents <span class="ml-2 text-[10px] bg-red-100 text-red-600 px-2 py-0.5 rounded">Compulsory</span>
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        <!-- Aadhaar Front -->
                        <div class="bg-white border-2 border-dashed border-gray-200 rounded-2xl p-5 transition-all hover:border-blue-400 group">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-all">
                                        <i class="fa-solid fa-id-card"></i>
                                    </div>
                                    <div>
                                        <h4 class="font-bold text-gray-900">Aadhaar Front</h4>
                                        <p class="text-[10px] text-gray-500">Front Display (PDF/JPG)</p>
                                    </div>
                                </div>
                                <% const hasAadhaarFront = user.documents.find(d => d.docType === 'aadhaar_front') %>
                                <% if (hasAadhaarFront) { %>
                                    <span class="text-green-500 bg-green-50 px-2 py-1 rounded text-[10px] font-bold uppercase"><i class="fa-solid fa-check"></i> Uploaded</span>
                                <% } %>
                            </div>
                            <button onclick="triggerUpload('aadhaar_front')" class="w-full py-3 bg-gray-900 text-white rounded-xl text-xs font-bold hover:bg-blue-600 transition-all flex items-center justify-center gap-2 shadow-lg shadow-gray-200">
                                <i class="fa-solid fa-cloud-arrow-up"></i> <%= hasAadhaarFront ? 'Re-upload Front' : 'Upload Front' %>
                            </button>
                        </div>

                        <!-- Aadhaar Back -->
                        <div class="bg-white border-2 border-dashed border-gray-200 rounded-2xl p-5 transition-all hover:border-blue-400 group">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-all">
                                        <i class="fa-solid fa-id-card"></i>
                                    </div>
                                    <div>
                                        <h4 class="font-bold text-gray-900">Aadhaar Back</h4>
                                        <p class="text-[10px] text-gray-500">Back Display (PDF/JPG)</p>
                                    </div>
                                </div>
                                <% const hasAadhaarBack = user.documents.find(d => d.docType === 'aadhaar_back') %>
                                <% if (hasAadhaarBack) { %>
                                    <span class="text-green-500 bg-green-50 px-2 py-1 rounded text-[10px] font-bold uppercase"><i class="fa-solid fa-check"></i> Uploaded</span>
                                <% } %>
                            </div>
                            <button onclick="triggerUpload('aadhaar_back')" class="w-full py-3 bg-gray-900 text-white rounded-xl text-xs font-bold hover:bg-blue-600 transition-all flex items-center justify-center gap-2 shadow-lg shadow-gray-200">
                                <i class="fa-solid fa-cloud-arrow-up"></i> <%= hasAadhaarBack ? 'Re-upload Back' : 'Upload Back' %>
                            </button>
                        </div>

                        <!-- PAN Card -->
                        <div class="bg-white border-2 border-dashed border-gray-200 rounded-2xl p-5 transition-all hover:border-blue-400 group">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-all">
                                        <i class="fa-solid fa-address-card"></i>
                                    </div>
                                    <div>
                                        <h4 class="font-bold text-gray-900">PAN Card</h4>
                                        <p class="text-xs text-gray-500">Clear Copy (PDF/JPG)</p>
                                    </div>
                                </div>
                                <% const hasPan = user.documents.find(d => d.docType === 'pan') %>
                                <% if (hasPan) { %>
                                    <span class="text-green-500 bg-green-50 px-2 py-1 rounded text-[10px] font-bold uppercase"><i class="fa-solid fa-check"></i> Uploaded</span>
                                <% } %>
                            </div>
                            <button onclick="triggerUpload('pan')" class="w-full py-3 bg-gray-900 text-white rounded-xl text-xs font-bold hover:bg-blue-600 transition-all flex items-center justify-center gap-2 shadow-lg shadow-gray-200">
                                <i class="fa-solid fa-cloud-arrow-up"></i> <%= hasPan ? 'Re-upload PAN Card' : 'Upload PAN Card' %>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Tax Documents Section -->
                <div class="mb-10">
                    <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-4 flex items-center">
                        <i class="fa-solid fa-file-invoice-dollar mr-2 text-green-500"></i> Tax & Income Proofs
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        <!-- Form 16 -->
                        <div class="bg-white border border-gray-200 rounded-2xl p-4 hover:shadow-lg transition-all border-l-4 border-l-green-500 flex flex-col h-full">
                            <h4 class="font-bold text-gray-900 text-sm mb-1 flex items-center justify-between">Form 16 <i class="fa-solid fa-file-invoice text-green-500"></i></h4>
                            <p class="text-[10px] text-gray-500 mb-4 tracking-tight">Salary Certificate from Employer</p>
                            <button onclick="triggerUpload('form16')" class="w-full mt-auto py-2.5 bg-green-50 text-green-700 rounded-lg text-xs font-black hover:bg-green-600 hover:text-white transition-all flex items-center justify-center gap-2">
                                <i class="fa-solid fa-upload"></i> Upload Form 16
                            </button>
                        </div>

                        <!-- TDS Certificate -->
                        <div class="bg-white border border-gray-200 rounded-2xl p-4 hover:shadow-lg transition-all border-l-4 border-l-blue-500 flex flex-col h-full">
                            <h4 class="font-bold text-gray-900 text-sm mb-1 flex items-center justify-between">TDS Certificate <i class="fa-solid fa-file-shield text-blue-500"></i></h4>
                            <p class="text-[10px] text-gray-500 mb-4 tracking-tight">Form 16A / TDS Proofs</p>
                            <button onclick="triggerUpload('tds')" class="w-full mt-auto py-2.5 bg-blue-50 text-blue-700 rounded-lg text-xs font-black hover:bg-blue-600 hover:text-white transition-all flex items-center justify-center gap-2">
                                <i class="fa-solid fa-upload"></i> Upload TDS Cert
                            </button>
                        </div>

                        <!-- Others -->
                        <div class="bg-gray-50 border border-gray-200 rounded-2xl p-4 border-l-4 border-l-purple-500 flex flex-col h-full">
                            <h4 class="font-bold text-gray-900 text-sm mb-1 flex items-center justify-between">Other Docs <i class="fa-solid fa-folder-plus text-purple-500"></i></h4>
                            <input type="text" id="otherLabel" placeholder="Enter Document Name..." class="w-full bg-white border border-gray-200 rounded-lg px-3 py-2 text-[10px] mb-2 focus:ring-2 focus:ring-purple-500 outline-none font-medium">
                            <button onclick="triggerUpload('others')" class="w-full mt-auto py-2.5 bg-purple-600 text-white rounded-lg text-xs font-black hover:bg-purple-700 transition-all flex items-center justify-center gap-2 shadow-lg shadow-purple-100">
                                <i class="fa-solid fa-plus-circle"></i> Upload Document
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Uploaded Documents List -->
                <div>
                    <h3 class="text-sm font-bold text-gray-900 mb-4">Recently Uploaded</h3>
                    <% if (!user.documents || user.documents.length === 0) { %>
                        <div class="bg-gray-50 rounded-2xl p-10 text-center border-2 border-dashed border-gray-200">
                            <div class="w-12 h-12 bg-white shadow-sm rounded-full flex items-center justify-center mx-auto mb-3 text-gray-300">
                                <i class="fa-solid fa-cloud-arrow-up text-xl"></i>
                            </div>
                            <p class="text-gray-500 text-xs">No documents uploaded yet. Please start by uploading Aadhaar and PAN.</p>
                        </div>
                    <% } else { %>
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3" id="docsList">
                            <% user.documents.slice().reverse().forEach(doc => { %>
                                <div class="bg-white border border-gray-100 p-3 rounded-xl shadow-sm flex items-center gap-3 group relative">
                                    <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 <%= 
                                        doc.docType.includes('aadhaar') ? 'bg-orange-50 text-orange-600' : 
                                        doc.docType === 'pan' ? 'bg-blue-50 text-blue-600' : 
                                        'bg-green-50 text-green-600' 
                                    %>">
                                        <i class="fa-solid <%= 
                                            doc.docType === 'form16' ? 'fa-file-invoice' : 
                                            doc.docType.includes('aadhaar') ? 'fa-id-card' : 
                                            doc.docType === 'pan' ? 'fa-address-card' : 'fa-file' 
                                        %> text-sm"></i>
                                    </div>
                                    <div class="flex-1 overflow-hidden">
                                        <p class="text-[11px] font-black text-gray-900 truncate">
                                            <%= doc.label || (doc.docType.charAt(0).toUpperCase() + doc.docType.slice(1)) %>
                                        </p>
                                        <p class="text-[9px] text-gray-500 truncate"><%= (doc.size / 1024).toFixed(1) %> KB • <%= new Date(doc.uploadedAt).toLocaleDateString() %></p>
                                    </div>
                                    
                                    <!-- Action Buttons -->
                                    <div class="flex items-center gap-2 ml-auto">
                                        <a href="/api/dashboard/documents/<%= doc._id %>/view" target="_blank" title="View Document" class="w-8 h-8 flex items-center justify-center bg-green-600 text-white rounded-lg hover:bg-green-700 transition-all shadow-md">
                                            <i class="fa-solid fa-eye text-[10px]"></i>
                                        </a>
                                        <button data-label="<%= doc.label || '' %>" onclick="editDocLabel('<%= doc._id %>', this.getAttribute('data-label'))" title="Edit Title" class="w-8 h-8 flex items-center justify-center bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-all shadow-md">
                                            <i class="fa-solid fa-pen text-[10px]"></i>
                                        </button>
                                        <button onclick="deleteDoc('<%= doc._id %>')" title="Delete Document" class="w-8 h-8 flex items-center justify-center bg-red-600 text-white rounded-lg hover:bg-red-700 transition-all shadow-md">
                                            <i class="fa-solid fa-trash text-[10px]"></i>
                                        </button>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>

                <!-- My Testimonials Section -->
                <div class="border-t border-gray-100 pt-10 mt-10">
                    <div class="flex items-center justify-between mb-8">
                        <h2 class="text-2xl font-black text-gray-900">My Testimonials</h2>
                        <button onclick="openTestimonialModal()" class="text-xs font-bold text-blue-600 bg-blue-50 px-3 py-1 rounded-full uppercase hover:bg-blue-100 transition-colors">Add New</button>
                    </div>
                    
                    <% if (!locals.userTestimonials || userTestimonials.length === 0) { %>
                        <div class="bg-gray-50 rounded-2xl p-6 text-center border-2 border-dashed border-gray-200">
                            <p class="text-gray-500 text-xs text-balance">You haven't submitted any testimonials yet. Share your feedback to help others!</p>
                        </div>
                    <% } else { %>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                            <% userTestimonials.forEach(t => { %>
                                <div class="bg-white border border-gray-100 p-5 rounded-2xl shadow-sm relative group overflow-hidden">
                                    <div class="flex justify-between items-start mb-2">
                                        <div class="flex text-yellow-500 text-xs">
                                            <% for(let i=1; i<=5; i++) { %>
                                                <i class="fa-star <%= i <= t.rating ? 'fa-solid' : 'fa-regular' %>"></i>
                                            <% } %>
                                        </div>
                                        <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                            <button 
                                                data-id="<%= t._id %>" 
                                                data-content="<%= t.content %>" 
                                                data-rating="<%= t.rating %>" 
                                                onclick="editMyTestimonialBtn(this)" 
                                                class="text-blue-500 hover:text-blue-700 bg-blue-50 w-7 h-7 rounded-full flex items-center justify-center transition-colors">
                                                <i class="fa-solid fa-pen text-[10px]"></i>
                                            </button>
                                            <button onclick="deleteMyTestimonial('<%= t._id %>')" class="text-red-500 hover:text-red-700 bg-red-50 w-7 h-7 rounded-full flex items-center justify-center transition-colors"><i class="fa-solid fa-trash text-[10px]"></i></button>
                                        </div>
                                    </div>
                                    <p class="text-xs text-gray-600 italic mb-3 line-clamp-3">"<%= t.content %>"</p>
                                    <div class="flex justify-between items-center mt-auto pt-3 border-t border-gray-50">
                                        <span class="text-[9px] text-gray-400 font-medium"><%= timeAgo(t.createdAt) %></span>
                                        <span class="text-[9px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider <%= t.isApproved ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>"><%= t.isApproved ? 'Approved' : 'Pending' %></span>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>

                <input type="file" id="fileUpload" class="hidden" onchange="handleFileUpload(event)">
            </div>
        </div>
    </div>
</div>

<script>
    function editMyTestimonialBtn(btn) {
        const { id, content, rating } = btn.dataset;
        openTestimonialModal({ id, content, rating });
    }

    async function deleteMyTestimonial(id) {
        const { isConfirmed } = await Swal.fire({
            title: 'Delete Testimonial?',
            text: 'Are you sure you want to delete this testimonial?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!'
        });
        if(!isConfirmed) return;

        try {
            const res = await fetch(`/api/testimonials/${id}`, { method: 'DELETE' });
            const data = await res.json();
            if(data.success) {
                if(typeof showPopup === 'function') {
                    showPopup({ title: 'Deleted', message: 'Testimonial removed.', type: 'success' });
                } else Swal.fire('Deleted!', 'Testimonial removed.', 'success');
                setTimeout(() => location.reload(), 1000);
            } else {
                Swal.fire('Error', data.error || 'Delete failed', 'error');
            }
        } catch(e) {
            Swal.fire('Error', 'Server error.', 'error');
        }
    }
</script>

<script>
    let currentDocType = '';

    function triggerUpload(type) {
        currentDocType = type;
        if (type === 'others' && !document.getElementById('otherLabel').value) {
            Swal.fire('Notice', 'Please enter a name for the "Other" document first.', 'info');
            document.getElementById('otherLabel').focus();
            return;
        }
        document.getElementById('fileUpload').click();
    }

    async function handleFileUpload(event) {
        const file = event.target.files[0];
        if (!file) return;

        const label = currentDocType === 'others' ? document.getElementById('otherLabel').value : '';
        
        Swal.fire({ title: 'Uploading...', text: 'Please wait while we secure your document.', icon: 'info' });

        const formData = new FormData();
        formData.append('document', file);
        formData.append('docType', currentDocType);
        formData.append('label', label);

        try {
            const response = await fetch('/api/dashboard/upload', {
                method: 'POST',
                body: formData
            });

            const data = await response.json();

            if (data.success) {
                Swal.fire('Success', 'Document uploaded successfully.', 'success');
                setTimeout(() => window.location.reload(), 1000);
            } else {
                throw new Error(data.error || 'Upload failed');
            }
        } catch (err) {
            console.error('File Upload Error:', err);
            Swal.fire('Upload Failed', err.message || 'Could not upload document.', 'error');
        }
    }

    async function editDocLabel(docId, currentLabel) {
        const { value: newLabel } = await Swal.fire({
            title: 'Rename Document',
            input: 'text',
            inputValue: currentLabel,
            showCancelButton: true,
            inputValidator: (value) => {
                if (!value) return 'You need to write something!'
            }
        });
        if (!newLabel || newLabel.trim() === '') return;

        try {
            const res = await fetch(`/api/dashboard/documents/${docId}`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ label: newLabel.trim() })
            });
            const data = await res.json();
            if (data.success) {
                window.location.reload();
            } else {
                Swal.fire('Error', data.error || 'Failed to update label', 'error');
            }
        } catch (err) {
            console.error('Edit Label Error:', err);
            Swal.fire('Error', 'Server error. Please try again.', 'error');
        }
    }

    async function deleteDoc(docId) {
        const { isConfirmed } = await Swal.fire({
            title: 'Delete Document?',
            text: 'Are you sure you want to permanently delete this document? This action cannot be undone.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Yes, delete it!'
        });
        if (!isConfirmed) return;

        try {
            const res = await fetch(`/api/dashboard/documents/${docId}`, {
                method: 'DELETE'
            });
            const data = await res.json();
            if (data.success) {
                Swal.fire('Deleted!', 'Document has been removed.', 'success');
                setTimeout(() => window.location.reload(), 1000);
            } else {
                Swal.fire('Error', data.error || 'Failed to delete document', 'error');
            }
        } catch (err) {
            console.error('Delete Doc Error:', err);
            Swal.fire('Error', 'Server error. Please try again.', 'error');
        }
    }

</script>
<span id="popup-config" data-show="<%= typeof shouldShowPopup !== 'undefined' ? (shouldShowPopup ? 'true' : 'false') : 'false' %>" style="display:none;"></span>
<script>
    const shouldShowPopup = document.getElementById('popup-config').dataset.show === 'true';
    if (shouldShowPopup) {
        document.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                openTestimonialModal();
                Swal.fire({ title: 'Feedback Request', text: 'Hi! Could you take a moment to leave us a review?', icon: 'info' });
            }, 1500); 
        });
    }
</script>
