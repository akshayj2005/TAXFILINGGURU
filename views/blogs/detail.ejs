<%- contentFor('body') %>

<div class="bg-white">
    <!-- HERO -->
    <section class="relative h-[60vh] min-h-[400px] flex items-center justify-center overflow-hidden">
        <img src="<%= blog.image %>" alt="<%= blog.title %>" class="absolute inset-0 w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/40 to-transparent"></div>
        
        <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
            <div class="flex justify-center mb-6">
                <span class="bg-blue-600/90 backdrop-blur-md text-white px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest animate-fadeInUp">
                    <%= blog.category %>
                </span>
            </div>
            <h1 class="text-4xl md:text-6xl font-black text-white mb-6 tracking-tight leading-tight animate-fadeInUp" style="animation-delay: 0.1s">
                <%= blog.title %>
            </h1>
            <div class="flex items-center justify-center gap-6 text-xs font-bold text-gray-300 uppercase tracking-widest animate-fadeInUp" style="animation-delay: 0.2s">
                <span><i class="fa-solid fa-user-pen mr-2 text-blue-400"></i> <%= blog.author %> (<%= blog.authorRole || 'Expert' %>)</span>
                <span class="w-1.5 h-1.5 bg-white/20 rounded-full"></span>
                <span><i class="fa-solid fa-calendar mr-2 text-blue-400"></i> <%= new Date(blog.createdAt).toLocaleDateString() %></span>
                <span class="w-1.5 h-1.5 bg-white/20 rounded-full"></span>
                <span><i class="fa-solid fa-eye mr-2 text-blue-400"></i> <%= blog.viewCount %> Views</span>
            </div>
        </div>
    </section>

    <!-- CONTENT -->
    <div class="max-w-7xl mx-auto py-24 px-4 flex flex-col lg:flex-row gap-16">
        <!-- Main Content -->
        <main class="lg:w-2/3">
            <div class="prose prose-lg prose-blue max-w-none text-gray-700 leading-relaxed font-medium">
                <%- blog.content %>
            </div>

            <!-- Tags -->
            <% if (blog.tags && blog.tags.length > 0) { %>
                <div class="mt-16 pt-8 border-t border-gray-100">
                    <h4 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Post Tags</h4>
                    <div class="flex flex-wrap gap-2">
                        <% blog.tags.forEach(tag => { %>
                            <span class="bg-gray-50 text-gray-600 px-4 py-2 rounded-xl text-xs font-bold hover:bg-blue-50 hover:text-blue-600 transition-colors cursor-default">
                                #<%= tag %>
                            </span>
                        <% }) %>
                    </div>
                </div>
            <% } %>

            <!-- Author Card -->
            <div class="mt-16 p-10 bg-blue-50 rounded-[3rem] flex flex-col md:flex-row items-center gap-8 border border-blue-100">
                <div class="w-24 h-24 bg-white rounded-3xl overflow-hidden shadow-xl shadow-blue-200/50">
                    <img src="<%= blog.authorImage || '/assets/images/TFG_LOGO.png' %>" alt="Author" class="w-full h-full object-cover">
                </div>
                <div class="text-center md:text-left">
                    <h4 class="text-xl font-black text-gray-900"><%= blog.author %></h4>
                    <p class="text-[10px] font-black text-blue-600 uppercase tracking-widest"><%= blog.authorRole || 'Super Administrator' %></p>
                    <p class="text-gray-600 mt-2 text-sm leading-relaxed">
                         <%= blog.authorBio || 'Expert team at TaxFilingGuru dedicated to helping individuals and businesses optimize their financial performance.' %>
                    </p>
                    <div class="mt-4 flex gap-4 justify-center md:justify-start">
                        <a href="#" class="w-8 h-8 rounded-lg bg-white flex items-center justify-center text-blue-600 hover:bg-blue-600 hover:text-white transition-all shadow-sm"><i class="fa-brands fa-linkedin-in"></i></a>
                        <a href="#" class="w-8 h-8 rounded-lg bg-white flex items-center justify-center text-blue-600 hover:bg-blue-600 hover:text-white transition-all shadow-sm"><i class="fa-brands fa-twitter"></i></a>
                    </div>
                </div>
            </div>
        </main>

        <!-- Sidebar -->
        <aside class="lg:w-1/3 space-y-12">
            <!-- Related Posts -->
            <% if (recentBlogs && recentBlogs.length > 0) { %>
                <div>
                    <h4 class="text-xl font-black text-gray-900 mb-8 flex items-center gap-3">
                        <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center text-sm"><i class="fa-solid fa-sparkles"></i></span>
                        Recent Articles
                    </h4>
                    <div class="space-y-6">
                        <% recentBlogs.forEach(rb => { %>
                            <a href="/blogs/<%= rb.slug %>" class="group flex items-center gap-4 p-4 rounded-2xl hover:bg-gray-50 transition-all border border-transparent hover:border-gray-100">
                                <img src="<%= rb.image %>" alt="" class="w-20 h-20 object-cover rounded-xl shadow-sm">
                                <div>
                                    <span class="text-[10px] font-black text-blue-600 uppercase tracking-widest"><%= rb.category %></span>
                                    <h5 class="text-sm font-bold text-gray-900 mt-1 line-clamp-2 group-hover:text-blue-600 transition-colors"><%= rb.title %></h5>
                                    <p class="text-[10px] text-gray-400 mt-1"><%= new Date(rb.createdAt).toLocaleDateString() %></p>
                                </div>
                            </a>
                        <% }) %>
                    </div>
                </div>
            <% } %>

            <!-- Consulting Box -->
            <div class="bg-gradient-to-br from-blue-600 to-indigo-800 rounded-[3rem] p-10 text-white shadow-2xl shadow-blue-200 relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -mr-16 -mt-16 blur-3xl"></div>
                <h4 class="text-2xl font-black tracking-tight mb-4 relative z-10">
                    <%= blog.ctaDescription || 'Need Expert Tax Help?' %>
                </h4>
                <p class="text-blue-100 text-sm leading-relaxed mb-8 opacity-90 relative z-10">
                    Get personalized solutions from our tax specialists. Professional assistance is just a click away.
                </p>
                <a href="<%= blog.ctaLink || '/reg?type=consultation' %>" class="block text-center py-4 bg-white text-blue-700 font-black text-xs uppercase tracking-widest rounded-2xl hover:bg-blue-50 transition-all shadow-lg relative z-10">
                    <%= blog.ctaText || 'Get Expert Help' %>
                </a>
            </div>
        </aside>
    </div>
</div>

<style>
    /* Content Styles for Rich Text */
    .prose h2 { font-size: 1.875rem; line-height: 2.25rem; font-weight: 900; color: #111827; margin-top: 3rem; margin-bottom: 1.5rem; letter-spacing: -0.025em; }
    .prose h3 { font-size: 1.5rem; line-height: 2rem; font-weight: 900; color: #111827; margin-top: 2.5rem; margin-bottom: 1.25rem; letter-spacing: -0.025em; }
    .prose p { color: #4b5563; margin-bottom: 1.5rem; }
    .prose ul { list-style-type: disc; list-style-position: inside; margin-bottom: 2rem; }
    .prose ul li { margin-bottom: 0.75rem; }
    .prose ol { list-style-type: decimal; list-style-position: inside; margin-bottom: 2rem; }
    .prose ol li { margin-bottom: 0.75rem; }
    .prose strong { color: #111827; font-weight: 900; }
    .prose a { color: #2563eb; font-weight: 700; text-decoration: underline; transition-property: color; transition-duration: 200ms; }
    .prose a:hover { color: #1d4ed8; }
    .prose blockquote { border-left-width: 4px; border-color: #2563eb; padding-left: 1.5rem; font-style: italic; color: #1f2937; margin-top: 2rem; margin-bottom: 2rem; background-color: #eff6ff; padding-top: 1rem; padding-bottom: 1rem; padding-right: 1rem; border-top-right-radius: 1rem; border-bottom-right-radius: 1rem; }
</style>
