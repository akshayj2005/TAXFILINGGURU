<%- include('partials/header') %>

<div class="page-header">
  <div>
    <h1>Author Management</h1>
    <p>Manage blog authors, roles, and expertise profiles.</p>
  </div>
  <div class="header-actions">
    <button class="btn btn-primary" onclick="openAuthorModal()">
      <i class="fa-solid fa-plus"></i> Add New Author
    </button>
  </div>
</div>

<div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px;">
  <% authors.forEach(author => { %>
    <div class="card author-card">
      <div class="card-padding">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 20px;">
          <img src="<%= author.image %>" alt="<%= author.name %>" style="width: 64px; height: 64px; border-radius: 12px; object-fit: cover; border: 2px solid var(--border);">
          <div>
            <h3 style="font-size: 16px; font-weight: 700;"><%= author.name %></h3>
            <p style="font-size: 12px; color: var(--accent); font-weight: 600;"><%= author.role %></p>
          </div>
        </div>
        <p style="font-size: 13px; color: var(--text-secondary); margin-bottom: 20px; line-height: 1.6;">
          <%= author.bio.substring(0, 100) %><%= author.bio.length > 100 ? '...' : '' %>
        </p>
        <div style="display: flex; gap: 8px;">
            <% if(author.socialLinks.linkedin) { %>
                <a href="<%= author.socialLinks.linkedin %>" target="_blank" style="color: #0077b5;"><i class="fa-brands fa-linkedin"></i></a>
            <% } %>
            <% if(author.socialLinks.twitter) { %>
                <a href="<%= author.socialLinks.twitter %>" target="_blank" style="color: #1da1f2;"><i class="fa-brands fa-twitter"></i></a>
            <% } %>
        </div>
        <div style="margin-top: 20px; display: flex; justify-content: flex-end; gap: 8px;">
          <button class="btn btn-sm btn-outline" onclick="initEditAuthor('<%= author._id %>')">Edit</button>
          <button class="btn btn-sm btn-outline" style="color: var(--danger);" onclick="deleteAuthor('<%= author._id %>')">Delete</button>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<!-- Add/Edit Modal -->
<div id="author-modal" class="modal">
  <div class="modal-content" style="max-width: 500px;">
    <div class="modal-header">
      <h2 id="modal-title">Add New Author</h2>
      <button class="close-btn" onclick="closeModal('author-modal')">&times;</button>
    </div>
    <div class="modal-body">
      <form id="author-form" enctype="multipart/form-data">
        <input type="hidden" name="id" id="author-id">
        
        <div class="form-group">
          <label class="form-label">Profile Image</label>
          <div id="author-image-preview" onclick="document.getElementById('author-image-input').click()" style="width: 80px; height: 80px; background: var(--bg-input); border-radius: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center; overflow: hidden; border: 1px solid var(--border);">
            <span class="text-muted" style="font-size: 11px;">Upload</span>
          </div>
          <input type="file" name="image" id="author-image-input" style="display: none;" accept="image/*" onchange="previewAuthorImage(this)">
        </div>

        <div class="form-group">
          <label class="form-label">Full Name *</label>
          <input type="text" class="form-control" name="name" id="author-name" required placeholder="Ex: Akshay Kumar">
        </div>

        <div class="form-group">
          <label class="form-label">Professional Role</label>
          <input type="text" class="form-control" name="role" id="author-role" value="Super Administrator">
        </div>

        <div class="form-group">
          <label class="form-label">Biography</label>
          <textarea class="form-control" name="bio" id="author-bio" rows="3" placeholder="Brief expert background..."></textarea>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">LinkedIn URL</label>
                <input type="text" class="form-control" name="linkedin" id="author-linkedin">
            </div>
            <div class="form-group">
                <label class="form-label">Twitter URL</label>
                <input type="text" class="form-control" name="twitter" id="author-twitter">
            </div>
        </div>
        
        <div class="form-group">
            <label class="form-label">Website</label>
            <input type="text" class="form-control" name="website" id="author-website">
        </div>

      </form>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('author-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="submitAuthorForm()">Save Author</button>
    </div>
  </div>
</div>

<script>
function openAuthorModal() {
  document.getElementById('author-form').reset();
  document.getElementById('author-id').value = '';
  document.getElementById('modal-title').innerText = 'Add New Author';
  document.getElementById('author-image-preview').innerHTML = '<span class="text-muted" style="font-size: 11px;">Upload</span>';
  document.getElementById('author-modal').style.display = 'flex';
}

function closeModal(id) {
  document.getElementById(id).style.display = 'none';
}

function previewAuthorImage(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = function(e) {
      document.getElementById('author-image-preview').innerHTML = `<img src="${e.target.result}" style="width: 100%; height: 100%; object-fit: cover;">`;
    }
    reader.readAsDataURL(input.files[0]);
  }
}

const allAuthors = <%- JSON.stringify(authors) %>;

function initEditAuthor(id) {
  const author = allAuthors.find(a => a._id === id);
  if (author) editAuthor(author);
}

function editAuthor(author) {
  document.getElementById('author-id').value = author._id;
  document.getElementById('author-name').value = author.name;
  document.getElementById('author-role').value = author.role;
  document.getElementById('author-bio').value = author.bio;
  document.getElementById('author-linkedin').value = author.socialLinks.linkedin || '';
  document.getElementById('author-twitter').value = author.socialLinks.twitter || '';
  document.getElementById('author-website').value = author.socialLinks.website || '';
  document.getElementById('author-image-preview').innerHTML = `<img src="${author.image}" style="width: 100%; height: 100%; object-fit: cover;">`;
  document.getElementById('modal-title').innerText = 'Edit Author';
  document.getElementById('author-modal').style.display = 'flex';
}

async function submitAuthorForm() {
  const form = document.getElementById('author-form');
  const formData = new FormData(form);
  const id = document.getElementById('author-id').value;
  const url = id ? `/admin/authors/${id}` : '/admin/authors/add';
  const method = id ? 'PUT' : 'POST';

  try {
    const response = await fetch(url, { method, body: formData });
    const result = await response.json();
    if (result.success) {
      location.reload();
    } else {
      Swal.fire('Error', result.error, 'error');
    }
  } catch (err) {
    console.error(err);
    alert('Something went wrong');
  }
}

async function deleteAuthor(id) {
  if (!confirm('Are you sure you want to delete this author?')) return;
  try {
    const response = await fetch(`/admin/authors/${id}`, { method: 'DELETE' });
    const result = await response.json();
    if (result.success) {
      location.reload();
    } else {
      showPopup({ title: 'Delete Failed', message: result.error || 'Could not delete author.', type: 'error' });
    }
  } catch (err) {
    console.error(err);
    showPopup({ title: 'System Error', message: 'Could not delete author.', type: 'error' });
  }
}
</script>

<%- include('partials/footer') %>
