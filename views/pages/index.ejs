<!-- Testimonials Section -->
<section id="testimonials" class="w-full py-6 md:py-20 px-4 bg-white">
  <div class="max-w-7xl mx-auto">

    <div class="text-center mb-8 md:mb-16">
      <h2 class="text-2xl md:text-4xl font-bold text-gray-900 mb-4">Trusted by Indians Worldwide</h2>
      <p class="text-gray-600 text-lg">Join thousands of taxpayers who file with confidence every year.</p>

      <div class="flex flex-wrap justify-center gap-6 mt-6 opacity-75">
        <div class="flex items-center space-x-2">
          <span class="text-yellow-500 text-xl font-bold"><%= avgRating %>/5</span>
          <span class="text-gray-500 text-sm">Customer Rating (<%= totalTestimonials %> Reviews)</span>
        </div>
        <div class="h-6 w-px bg-gray-300 hidden md:block"></div>
        <div class="flex items-center space-x-2">
          <span class="text-gray-900 font-semibold">100%</span>
          <span class="text-gray-500 text-sm">Data Privacy</span>
        </div>
      </div>
    </div>

    <div class="relative group">
      <!-- Scroll Buttons -->
      <button onclick="scrollTestimonials(this, -1)"
        class="hidden md:flex absolute -left-4 top-1/2 -translate-y-1/2 z-10 w-12 h-12 bg-white rounded-full shadow-lg items-center justify-center text-blue-600 hover:bg-blue-50 hover:scale-110 active:scale-95 transition-all duration-300 opacity-0 group-hover:opacity-100 border border-gray-100">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <div class="flex flex-col md:flex-row gap-6 md:overflow-x-auto scroll-smooth no-scrollbar p-2 -m-2 items-stretch" data-scroll-container>
        <% if (locals.testimonials && testimonials.length > 0) { %>
          <% testimonials.forEach(t => { %>
            <div
              class="bg-gray-50 p-8 rounded-2xl border border-gray-100 flex flex-col h-full hover:shadow-lg transition duration-300 w-full md:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)] flex-shrink-0 min-h-[300px]">
              <div class="flex text-yellow-400 mb-4 h-5">
                <% for(let i=0; i<5; i++) { %>
                  <svg class="w-5 h-5 <%= i < t.rating ? 'fill-current' : 'text-gray-300 h-5' %>" viewBox="0 0 20 20">
                    <path
                      d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                <% } %>
              </div>
              <p class="text-gray-700 italic mb-6 flex-grow leading-relaxed">
                "<%= t.content %>"
              </p>
              <div class="flex items-center">
                <div class="w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold mr-4">
                  <%= t.name ? t.name.charAt(0).toUpperCase() : 'U' %>
                </div>
                <div>
                  <h4 class="font-bold text-gray-900"><%= t.name %></h4>
                  <p class="text-gray-500 text-sm font-medium">
                    <%= t.role %> &bull; <span class="italic text-gray-400 font-normal"><%= timeAgo(t.createdAt) %></span>
                  </p>
                </div>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="w-full text-center py-10 text-gray-400">
            No testimonials found. Be the first to share your story!
          </div>
        <% } %>
      </div>

      <button onclick="scrollTestimonials(this, 1)"
        class="hidden md:flex absolute -right-4 top-1/2 -translate-y-1/2 z-10 w-12 h-12 bg-white rounded-full shadow-lg items-center justify-center text-blue-600 hover:bg-blue-50 hover:scale-110 active:scale-95 transition-all duration-300 opacity-0 group-hover:opacity-100 border border-gray-100">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>

    <!-- Add Testimonial Button -->
    <div class="text-center mt-12">
        <button onclick="openTestimonialModal()" class="inline-flex items-center gap-2 bg-white border-2 border-blue-600 text-blue-600 font-bold px-8 py-3 rounded-full hover:bg-blue-50 transition-all duration-300">
            <i class="fa-solid fa-pen-to-square"></i> Share Your Story
        </button>
    </div>
  </div>
</section>

<script>
  function scrollTestimonials(btn, direction) {
    const container = btn.parentElement.querySelector('[data-scroll-container]');
    const card = container.querySelector('div:not(.hidden)');
    if (!card) return;
    const cardWidth = card.offsetWidth + 24; // card width + gap-6 (24px)
    container.scrollBy({ left: direction * cardWidth, behavior: 'smooth' });
  }

  function openTestimonialModal() {
    const modal = document.getElementById('testimonialModal');
    if (modal) {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }
  }
</script>


