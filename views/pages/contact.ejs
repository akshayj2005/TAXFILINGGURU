                  // update country select
                  for (var i = 0; i < countrySelect.options.length; i++) {
                      if (countrySelect.options[i].value === d.country_name) {
                          countrySelect.value = d.country_name;
                          // trigger change event to sync phone
                          countrySelect.dispatchEvent(new Event('change'));
                          break;
                      }
                  }
              }
            }).catch(function() {});
              
          // Sync country change to phone code
          const contactCountry = document.getElementById("contactCountry");
          const contactPhoneCode = document.getElementById("contactPhoneCode");
          if (contactCountry && contactPhoneCode) {
              contactCountry.addEventListener('change', function() {
                  const cName = this.value;
                  for (let i = 0; i < contactPhoneCode.options.length; i++) {
                      if (contactPhoneCode.options[i].getAttribute('data-country') === cName) {
                          contactPhoneCode.selectedIndex = i;
                          break;
                      }
                  }
              });
          }

          document.getElementById('contactForm')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const btn = document.getElementById('contactSubmitBtn');
            const spinner = document.getElementById('contactSpinner');
            const overlay = document.getElementById('thankYouOverlay');
            const thankYouText = document.getElementById('thankYouText');
            
            // Disable button and show spinner
            btn.disabled = true;
            btn.querySelector('span').innerText = 'Sending...';
            spinner.classList.remove('hidden');
            
            const formData = {
              name: document.getElementById('contactName').value,
              email: document.getElementById('contactEmail').value,
              phone: (function(){ let p = (document.getElementById('contactPhone').value || '').trim(); return p ? (document.getElementById('contactPhoneCode').value + p) : ''; })(),
              country: document.getElementById('contactCountry').value,
              subject: document.getElementById('contactSubject').value,
              message: document.getElementById('contactMessage').value
            };
            
            try {
              const response = await fetch('/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
              });
              
              const result = await response.json();
              
              if (result.success) {
                thankYouText.innerText = result.message;
                overlay.classList.remove('hidden');
              } else {
                Swal.fire('Error', result.error || 'Something went wrong. Please try again.', 'error');
              }
            } catch (err) {
              console.error('Submission error:', err);
              Swal.fire('Error', 'Network error. Please check your connection.', 'error');
            } finally {
              btn.disabled = false;
              btn.querySelector('span').innerText = 'Send Message';
              spinner.classList.add('hidden');
            }
          });

          function resetContactForm() {
            document.getElementById('contactForm').reset();
            document.getElementById('thankYouOverlay').classList.add('hidden');
          }
        </script>
      </div>
    </section>
  </div>
</div>
