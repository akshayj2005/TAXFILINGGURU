          </button>
        </div>

        <div id="fp_step3" class="hidden mt-4 pt-4 border-t border-gray-100">
          <p class="text-xs text-green-600 mb-3 font-bold uppercase"><i class="fa-solid fa-lock"></i> Set New Password</p>
          <div class="relative mb-4">
            <input id="fp_newpass" type="password" placeholder="Minimum 6 characters"
              class="w-full px-4 py-3 border rounded-lg pr-12 outline-none focus:ring-2 focus:ring-green-500">
            <button type="button" onclick="togglePasswordVisibility('fp_newpass', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-blue-600 transition-colors p-2">
              <i class="fa-solid fa-eye-slash"></i>
            </button>
          </div>
          <button onclick="resetPasswordNow()" class="w-full bg-green-600 text-white py-3 rounded-lg font-bold hover:bg-green-700 transition">
            Update Password
          </button>
