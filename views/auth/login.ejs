</main>

</div>
<script>
  const type = new URLSearchParams(window.location.search).get("type");

  const pamphlet = document.getElementById("pamphlet");
  const heroTitle = document.getElementById("page-title");
  const heroSubtitle = document.getElementById("page-subtitle");


  let bgImage = "/assets/images/pamphlet-resident.jpg";

  if (type === "nri") {
    bgImage = "/assets/images/pamphlet-nri.jpg";
    heroTitle.innerText = "NRI Login";
    heroSubtitle.innerText =
      "Specialized tax filing for foreign income, DTAA & global compliance. \n Expert handling of overseas income and Indian tax obligations.";
    document.title = "NRI Login - Tax Filing Guru";
  }

  // ---------- LATEST OFFERS CONFIGURATION ----------
  const offersData = {
    badge: "🔥 LATEST OFFERS",
    heading: "Save BIG on Tax Filing!",
    description: "Login now to claim your exclusive discounts and benefits for this tax season.",
    features: [
      "Flat 20% OFF on all Premium ITR Filing packages",
      "Free Expert CA Consultation worth ₹499",
      "Priority Support & Notice Management for 1 Year"
    ]
  };

  // Render Offers Card inside the pamphlet
  if (pamphlet) {
    pamphlet.innerHTML = `
        <!-- Full Background Layer -->
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 scale-105" 
                 style="background-image: url('${bgImage}'); filter: blur(6px);">
            </div>
            <div class="absolute inset-0 bg-black/15"></div>
        </div>

        <!-- Centered Offers Card -->
        <div class="relative z-10 bg-white/95 backdrop-blur-sm rounded-2xl shadow-2xl p-6 md:p-10 w-[95%] md:w-[90%] max-w-lg border border-white/20">
          
          <div class="inline-block bg-red-100 text-red-600 font-bold px-3 py-1 rounded-full text-xs mb-4 shadow-sm tracking-wide">
            ${offersData.badge}
          </div>
                  
          <h3 class="text-3xl md:text-3xl font-black mb-3 text-gray-900 leading-tight tracking-tight">${offersData.heading}</h3>

          <p class="text-gray-600 text-base mb-5 leading-relaxed border-b border-gray-200 pb-4">${offersData.description}</p>

          <ul class="space-y-4">
            ${offersData.features.map(f =>
      '<li class="flex items-start text-gray-800 text-base font-semibold">' +
      '<svg class="w-6 h-6 text-green-500 mr-2 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">' +
      '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>' +
      '</svg>' + f + '</li>'
    ).join("")}
          </ul>
        </div>
      `;
  }
  function togglePasswordVisibility(inputId, btn) {
    const input = document.getElementById(inputId);
    const icon = btn.querySelector('i');
    if (input.type === 'password') {
      input.type = 'text';
      icon.classList.replace('fa-eye-slash', 'fa-eye');
    } else {
      input.type = 'password';
      icon.classList.replace('fa-eye', 'fa-eye-slash');
    }
  }

  function setLoginMethod(method) {
    const btnEmail = document.getElementById('btn-email');
    const btnMobile = document.getElementById('btn-mobile');
    const phoneCode = document.getElementById('loginPhoneCode');
    const useridInput = document.getElementById('userid');

    if (method === 'email') {
      btnEmail.className = "px-6 py-2.5 rounded-lg text-sm font-bold transition-all bg-white text-blue-600 shadow-sm flex items-center gap-2";
      btnMobile.className = "px-6 py-2.5 rounded-lg text-sm font-bold transition-all text-gray-500 hover:text-gray-700 flex items-center gap-2";
      phoneCode.classList.add('hidden');
      useridInput.placeholder = "Enter Registered Email*";
      useridInput.type = "email";
    } else {
      btnMobile.className = "px-6 py-2.5 rounded-lg text-sm font-bold transition-all bg-white text-blue-600 shadow-sm flex items-center gap-2";
      btnEmail.className = "px-6 py-2.5 rounded-lg text-sm font-bold transition-all text-gray-500 hover:text-gray-700 flex items-center gap-2";
      phoneCode.classList.remove('hidden');
      useridInput.placeholder = "Enter Mobile Number*";
      useridInput.type = "tel";
    }
  }

  document.getElementById("loginForm").addEventListener("submit", async function (e) {
    e.preventDefault();

    let userIdRaw = document.getElementById("userid").value.trim();
    const phoneCode = document.getElementById("loginPhoneCode").value;
    
    // Prepend phone code if it looks like a phone number (just numbers)
    let userId = userIdRaw;
    if (/^\d+$/.test(userIdRaw)) {
        userId = phoneCode + userIdRaw;
    }
    const password = document.getElementById("loginPassword").value.trim();

    if (!userId || !password) {
      showPopup({ title: 'Input Required', message: 'Please enter both User ID and Password.', type: 'warning' });
      return;
    }

    const loginBtn = this.querySelector('button[type="submit"]');
    const originalText = loginBtn.innerHTML;
    loginBtn.disabled = true;
    loginBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Authenticating...';

    try {
      const response = await fetch('/api/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, password, type: type || 'resident' })
      });

      const data = await response.json();

      if (data.success) {
        localStorage.setItem("loginType", data.loginType);
        showPopup({
          title: 'Login Successful',
          message: 'Welcome back! Redirecting to your dashboard...',
          type: 'success',
          callback: () => onLoginSuccess()
        });
      } else {
        showPopup({ title: 'Login Failed', message: data.error || 'Invalid User ID or Password.', type: 'error' });
      }
    } catch (err) {
      console.error('Login error:', err);
      showPopup({ title: 'System Error', message: 'Could not connect to the authentication server.', type: 'error' });
    } finally {
      loginBtn.disabled = false;
      loginBtn.innerHTML = originalText;
    }
  });

  // ----------------------------
  // YOUR REDIRECT FUNCTION (UNCHANGED)
  // ----------------------------
  function onLoginSuccess() {
    window.location.href = "/dashboard";
    localStorage.removeItem("loginType");
  }

  function openForgotPassword() {
    document.getElementById("forgotPasswordModal").classList.remove("hidden");
    resetFpSteps();
  }
  function closeForgotPassword() {
    document.getElementById("forgotPasswordModal").classList.add("hidden");
  }
  function resetFpSteps() {
    document.getElementById("fp_step1").classList.remove("hidden");
    document.getElementById("fp_step2").classList.add("hidden");
    document.getElementById("fp_step3").classList.add("hidden");
    document.getElementById("fp_userid").value = "";
    document.getElementById("fp_otp").value = "";
    document.getElementById("fp_newpass").value = "";
  }

  function openForgotUserId() {
    // Removed
  }
  function closeForgotUserId() {
    // Removed
  }
  function resetFuidSteps() {
    // Removed
  }

  async function sendOtp() {
    const userId = document.getElementById("fp_userid").value.trim();
    if (!userId) {
      showPopup({ title: 'Error', message: 'Please enter your User ID or Email.', type: 'error' });
      return;
    }

    try {
      const resp = await fetch('/api/auth/forgot-password-otp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, type: type || 'resident' })
      });
      const data = await resp.json();
      if (data.success) {
        showPopup({ title: 'Step 1 Complete', message: '📩 ' + data.message, type: 'info' });
        document.getElementById("fp_step1").classList.add("hidden");
        document.getElementById("fp_step2").classList.remove("hidden");
      } else {
        showPopup({ title: 'Error', message: data.error, type: 'error' });
      }
    } catch (err) {
      showPopup({ title: 'System Error', message: 'Could not send OTP.', type: 'error' });
    }
  }

  async function verifyResetOtp() {
    const userId = document.getElementById("fp_userid").value.trim();
    const otp = document.getElementById("fp_otp").value.trim();
    if (!otp) return showPopup({ title: 'Error', message: 'Please enter OTP', type: 'error' });

    try {
      const resp = await fetch('/api/auth/verify-reset-otp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, otp, type: type || 'resident' })
      });
      const data = await resp.json();
      if (data.success) {
        showPopup({ title: 'OTP Verified', message: '✅ ' + data.message, type: 'success' });
        document.getElementById("fp_step2").classList.add("hidden");
        document.getElementById("fp_step3").classList.remove("hidden");
      } else {
        showPopup({ title: 'Error', message: data.error, type: 'error' });
      }
    } catch (err) {
      showPopup({ title: 'Error', message: 'Verification failed', type: 'error' });
    }
  }

  async function resetPasswordNow() {
    const userId = document.getElementById("fp_userid").value.trim();
    const otp = document.getElementById("fp_otp").value.trim();
    const newPassword = document.getElementById("fp_newpass").value.trim();

    if (newPassword.length < 6) return showPopup({ title: 'Error', message: 'Password must be at least 6 characters', type: 'error' });

    try {
      const resp = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, otp, newPassword, type: type || 'resident' })
      });
      const data = await resp.json();
      if (data.success) {
        showPopup({
          title: 'Success',
          message: '✅ ' + data.message,
          type: 'success',
          callback: () => closeForgotPassword()
        });
      } else {
        showPopup({ title: 'Error', message: data.error, type: 'error' });
      }
    } catch (err) {
      showPopup({ title: 'System Error', message: 'Could not reset password.', type: 'error' });
    }
  }

  function newCustomerAlert() {
    showPopup({
      title: 'New Customer?',
      message: 'You need to choose Resident or NRI before continuing.',
      type: 'info',
      showCancel: true,
      confirmText: 'Go to Main Page',
      callback: (confirmed) => {
        if (confirmed) {
          window.location.href = "/";
        }
      }
    });
  }
  // Fetch IP to set country code
  document.addEventListener('DOMContentLoaded', () => {
      fetch('https://ipapi.co/json/')
          .then(r => r.json())
          .then(d => {
              if (d && d.country_name) {
                  const cc = document.getElementById('loginPhoneCode');
                  if (cc) {
                      for (let i = 0; i < cc.options.length; i++) {
                          if (cc.options[i].getAttribute('data-country') === d.country_name) {
                              cc.selectedIndex = i;
                              break;
                          }
                      }
                  }
              }
          }).catch(() => {});
  });
</script>
