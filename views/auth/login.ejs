          <input id="fp_otp" placeholder="Enter 6-digit OTP" class="w-full mb-3 px-4 py-3 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
          <button onclick="verifyResetOtp()" class="w-full bg-blue-600 text-white py-3 rounded-lg font-bold hover:bg-blue-700 transition">
