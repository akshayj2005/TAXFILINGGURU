        <div id="fp_step1">
          <input id="fp_userid" placeholder="Enter User ID or Email" class="w-full mb-3 px-4 py-3 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
          <button onclick="sendOtp()" class="w-full bg-blue-600 text-white py-3 rounded-lg font-bold hover:bg-blue-700 transition">
            Send Reset OTP
          </button>
        </div>

        <div id="fp_step2" class="hidden mt-4 pt-4 border-t border-gray-100">
